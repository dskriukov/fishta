{
  "name": "ds-ref",
  "displayName": "DS Ref",
  "publisher": "local",
  "version": "0.0.6",
  "engines": { "vscode": "^1.80.0" },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "icon": "images/IA-logo.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "domain-sense",
          "title": "Domain Sense",
          "icon": "images/IA-logo.svg"
        }
      ]
    },
    "views": {
      "domain-sense": [
        {
          "id": "domain-sense.requirements",
          "name": "Sense Requirements"
        },
        {
          "id": "domain-sense.panel",
          "name": "Domain Panel",
          "type": "webview"
        },
        {
          "id": "domain-sense.stage",
          "name": "Current Stage",
          "type": "webview"
        },
        {
          "id": "domain-sense.actions",
          "name": "DS Actions",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "domain-sense.refresh",
        "title": "Domain Sense: Refresh"
      },
      {
        "command": "domain-sense.openMainSense",
        "title": "Domain Sense: Open Main Sense"
      },
      {
        "command": "domain-sense.openDsMap",
        "title": "Domain Sense: Open .dsmap"
      },
      {
        "command": "domain-sense.openContract",
        "title": "Domain Sense: Open Contract"
      },
      {
        "command": "domain-sense.openConfig",
        "title": "Domain Sense: Open Workspace Config"
      },
      {
        "command": "domain-sense.generateAgents",
        "title": "Domain Sense: Generate/Update AGENTS.md"
      },
      {
        "command": "domain-sense.fixCodeLinks",
        "title": "Domain Sense: Try to Fix Code Links"
      },
      {
        "command": "domain-sense.runDS",
        "title": "Domain Sense: Prepare DS"
      },
      {
        "command": "domain-sense.runDSC",
        "title": "Domain Sense: Prepare DSC"
      },
      {
        "command": "domain-sense.runDSR",
        "title": "Domain Sense: Prepare DSR"
      },
      {
        "command": "domain-sense.runIMP",
        "title": "Domain Sense: Prepare IMP"
      },
      {
        "command": "domain-sense.runFIX",
        "title": "Domain Sense: Prepare FIX"
      },
      {
        "command": "domain-sense.runREF",
        "title": "Domain Sense: Prepare REF"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "domain-sense.refresh",
          "when": "view == domain-sense.requirements || view == domain-sense.panel || view == domain-sense.stage || view == domain-sense.actions",
          "group": "navigation"
        },
        {
          "command": "domain-sense.openMainSense",
          "when": "view == domain-sense.requirements",
          "group": "navigation"
        },
        {
          "command": "domain-sense.openDsMap",
          "when": "view == domain-sense.stage || view == domain-sense.panel",
          "group": "navigation"
        },
        {
          "command": "domain-sense.openContract",
          "when": "view == domain-sense.stage || view == domain-sense.panel || view == domain-sense.actions",
          "group": "navigation"
        },
        {
          "command": "domain-sense.openConfig",
          "when": "view == domain-sense.stage || view == domain-sense.panel || view == domain-sense.actions",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "domain-sense",
        "aliases": ["Domain Sense", "domain-sense", "ds"],
        "extensions": [".ds", ".ia", ".fix"]
      },
      {
        "id": "domain-sense-dsc",
        "aliases": ["Domain Sense Config", "dsc"],
        "extensions": [".dsc"]
      },
      {
        "id": "domain-sense-dsr",
        "aliases": ["Domain Sense Rules", "dsr"],
        "extensions": [".dsr"]
      },
      {
        "id": "domain-sense-air",
        "aliases": ["Domain Sense AIR", "air"],
        "extensions": [".air"]
      }
    ],
    "grammars": [
      {
        "language": "domain-sense",
        "scopeName": "source.domain-sense",
        "path": "./syntaxes/domain-sense.tmLanguage.json"
      },
      {
        "language": "domain-sense-dsc",
        "scopeName": "source.domain-sense.dsc",
        "path": "./syntaxes/domain-sense-dsc.tmLanguage.json"
      },
      {
        "language": "domain-sense-dsr",
        "scopeName": "source.domain-sense.dsr",
        "path": "./syntaxes/domain-sense-dsr.tmLanguage.json"
      },
      {
        "language": "domain-sense-air",
        "scopeName": "source.domain-sense.air",
        "path": "./syntaxes/domain-sense-air.tmLanguage.json"
      },
      {
        "scopeName": "source.domain-sense.injection",
        "path": "./syntaxes/domain-sense-injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown",
          "source.yaml"
        ]
      }
    ]
  }
}
