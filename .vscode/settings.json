{
  "files.associations": {
    "*.ds": "markdown",
    "*.ia": "markdown",
    "*.fix": "markdown",
    "*.air": "yaml",
    "*.dsc": "yaml"
  },
  "chat.tools.terminal.autoApprove": {
    "/^sha1sum ds/sense/world/world\\.ds$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^sha1sum ds/sense/world/world\\.ds ds/fix/background\\.fix$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^sha1sum ds/sense/controls/controls\\.ds$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^sha1sum ds/sense/main\\.ds \\| cut -c1-8$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "sha1sum": true,
    "shasum": true
  }
}
