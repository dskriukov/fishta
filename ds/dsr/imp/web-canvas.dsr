  fish.updateSwimMotion:                    fish.js#updateSwimMotion render.js#drawFish render.js#easedCyclicPhase render.js#cubicBezierEase constants.js#SWIM.finTimingCurve constants.js#SWIM.finBurstTimingCurve  # @ds:bd354b7a @ds:df06827a @ia:3a4b5c6e @fix:2e7a4c91
  fish.regimeShapeVisual:                   render.js#drawFish  # @ds:1e323735 @ds:df06827a
  fish.updateFearEye:                       fish.js#updateFearEye  # @ds:906be50b @ia:7d8e9f0a
  fish.updateUserLabel:                     fish.js#updateUserLabel  # @ds:c5a92431
  fish.updateAbandonedGradient:             fish.js#updateAbandonedGradient  # @ds:c3708d14 @ds:bfd5a97a
  fish.updateSizeDeltaLabels:                main.js#updateSizeDeltaLabels render.js#drawSizeDeltaLabel  # @ds:c2d7f4a1
  fish.bodyColorVisual:                     render.js#drawFish  # @ia:32288dfb @ds:f883f90c
  fish.runExhaleCycle:                      fish.js#requestExhale fish.js#runExhaleCycle fish.js#makeExhaleBubble  # @ds:a44b9d2c @fn:a9a3ed12
  fish.serializeFish:                       fish.js#serializeFish  # @do:a7a50f7b
  prey.wanderSteer:                         prey.js#wanderSteer  # @ds:31cb7a0d
  prey.continuousMotionIntent:               prey.js#wanderSteer prey.js#chooseNpcIntent  # @ds:b47c2d91
  prey.fleeSteer:                           prey.js#fleeSteer  # @ds:579e4888 @ds:e699c42d
  prey.chooseNpcIntent:                     prey.js#chooseNpcIntent prey.js#tryCompromiseHunt prey.js#pursueIntent prey.js#huntTargetKey prey.js#huntBaseDirection prey.js#huntMotionForStrategy prey.js#assignNpcCourage prey.js#findSelectedFood prey.js#groupShredTargets prey.js#shouldContinueFleeFear prey.js#findNearestThreatWithin  # @ds:d0ef4576 @ds:e29aeb93 @ds:8f1a2c3d @ds:9b4e6d7f @ds:4e7a9c2d @ia:7a6b5c4d @ia:5b8d1f6a @fix:2a7e5c19 @fix:9d4e7b21
  prey.dangerAwareSteering:                 prey.js#chooseDangerAwareDirection prey.js#dangerScoreForDirection prey.js#immediateDangerForDirection prey.js#dangerPredictionPositions prey.js#dangerSampleAtPosition prey.js#smoothNpcSteering  # @ds:92d5b0c1 @ds:7cb92a44 @ds:4f58a1cd @ds:c6d7e8f9 @ia:8a4b2f19 @fix:5e1a7c42 @fix:8c4e1a72
  prey.maintainPopulation:                  prey.js#maintainPopulation  # @ds:e6ecfbdd @ds:53db39eb @ds:7ba4084c
  prey.growSpawnedFryToNominalSize:         prey.js#advanceFryGrowth  # @ds:e6ecfbdd
  prey.expireOldNpcFish:                     prey.js#expireOldNpcFish step.js#stepAuthoritativeWorld  # @ds:a6c9e8b4 @ds:d140effd
