  SHRED.colorFactorMaxDifferent: 0.7   # @ds:b6f08d21
  SHRED.hueWeight/saturationWeight: "HSV similarity weights" # @ds:b6f08d21
  SHRED.layerRotationMin/MaxDeg: "3..5 degrees" # @ds:73b91e4c
  SHRED.layerDriftPx: "small visual drift amplitude" # @ds:73b91e4c
  REGIME.cruiseFactor: 0.61           # @ia:5e6f7a8b
  PLAYER.startSize: 1                 # @ds:39305789
  FISH.minBurstSpeed: "greater than PREY.maxSpeed + PREY.speedMargin; predator/user hunt floor, not fleeing-prey cap" # @ds:8869f043 @ds:d4f6a1c2 @ia:2d3e4f5a
  GROWTH.fishAreaGainRatio: 0.7       # @ds:d867989f
