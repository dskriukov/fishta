  FLOW_MAP.vectorLineWidth: "linear impulse vector stroke width" # @fix:5f2a8c71
  FLOW_MAP.vectorCrossLineWidth: "rotating cross stroke width" # @fix:5f2a8c71
  FLOW_MAP.vectorCrossAlpha: "rotating cross opacity separate from vector opacity" # @fix:5f2a8c71
  FLOW_MAP.vectorAlpha: "gameplay overlay cross/vector opacity" # @fix:5f2a8c71
