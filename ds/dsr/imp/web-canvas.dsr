data_model:
  world:
    fields:
      width: number
      height: number
      nextSizeStep: "optional server resize target"
      fish: "array of all fish, user and NPC"
      shreds: "array of edible server-owned drifting shreds"
      bubbles: "server-side legacy field only; server sync does not transmit bubbles"
      tick: integer
  client_render:
    fields:
      snapshotBuffer: "recent authoritative world snapshots with receivedAt timestamps"
      clientBubbles: "client-owned bubble array; never assigned from protocol snapshots"
      clientBubbleEmitters: "Map fishId -> { bubbleTimer, bubbleBurstRemaining } for client-only decorative bubble generation"
      gameMenuOpen: "boolean controlling the top-left game menu panel"
      debugMode: "boolean toggled by game menu UI/keyboard; never sent to server"
      debugPositionTraces: "array of { kind:'relative'|'absolute', pos:{x,y}, createdAt, fadeStartAt, alpha?, fishId? }"
      worldMapVisible: "boolean toggled by the top-right map button; never sent to server"
      worldSnapshotInfo: "bottom-left render-only DOM panel derived from the latest WebSocket-synchronized world.fish and world.shreds arrays"
      latestAbsoluteServerPositions: "Map fishId -> absolute server pos captured from absolute sync diagnostics"
      lastDebugTraceAt: "timestamp of last debug trace sample, used to cap trace density"
      lastSentInputKey: "encoded comparison key for immediate input flush"
      lastInputFlushAt: "timestamp for unchanged-input idle cadence"
  fish:
    common_fields:
      - id
      - ownerKind              # user|npc
      - pos
      - vel
      - size
      - radius
      - facing
      - mode                   # cruise|burst
      - speedLevel             # 0 for no thrust, 1..30 cruise relative speed, 31..99 burst relative speed
      - age
      - playerActiveAge          # user active lifetime after start window, synchronized for lifetime UI
      - fryAge                   # active for NPC fry and user 3s start-window protection
      - nominalStartSize         # target size for fry growth
      - eatenFishCount
      - visual/decor state
  shred:
    fields:
      - id
      - pos
      - vel
      - size
      - radius
      - geometricArea
      - initialGeometricArea
      - sourceColor
      - remainingLayers
      - drag
      - visualSeed
      - decayAge
      - decayIntervalSeconds derived from SHRED.decayIntervalSeconds
    user_fields:
      - clientId
      - temporaryConnectionCode
      - userName
      - userColor
      - userTier               # paid|free
    npc_fields:
      - npcRole                # prey|abandoned-user-fish
      - formerUserColor?
      - fryAge?
      - nominalStartSize?
      - courage                # 0..100 NPC conflict tendency
      - steerDecision          # { desired, accel, nextAt } smoothed NPC steering state
  server_client_state:
    server_owns:
      - fish existence and ownerKind
      - eating and respawn events
      - NPC motivations
      - synchronizing coordinates
      - world scale
    client_owns:
      - current input
      - join form draft values
  server_performance_statistics:
    fields:
      windowStartedAt: "monotonic timestamp at the beginning of the current five-second reporting window"
      worldIterationCount: "authoritative step samples in the current window"
      worldIterationTotalMs: "sum of stepAuthoritativeWorld elapsed durations"
      controlledObjectTotal: "sum of world.fish.length + world.shreds.length after each authoritative step"
      preparedSyncCycleCount: "broadcastWorldSync invocations in the current window"
      droppedFragmentCount: "unsubmitted common-phase messages discarded by a newer cycle"
      phaseTotalMs: "sum of common delivery phase durations"
      phaseCount: "completed common delivery phases"
      syncAckCount: "received v:N confirmations in the current window"
      - render interpolation and prediction cache
      - decorative bubble emission, advancement, and rendering
      - size delta label accumulation, lifetime, current user size metric, and rendering for the current user fish only
      - world snapshot information panel derived from the latest received WebSocket snapshot
      - background asset loading and client-only background rendering

implementation_instructions:
  runtime_background_assets: |
    Publish the canonical PNG backgrounds by keeping runtime copies at
    web-canvas/assets/back.png and web-canvas/assets/start.png. Browser code and
    CSS must reference the web-canvas/assets paths, never ds/assets paths, so the
    locally served web-canvas directory and any published bundle resolve the same
    assets.  # @ia:3983084a
  local_server: |
    server.js serves static files from web-canvas/ and opens a WebSocket endpoint.
    The server runs the authoritative world step at a fixed tick rate.
    Connected clients send compact input messages for their own user fish only.
    Server broadcasts compact state strings shared by all clients; per-client messages are limited to identity and events.  # @ds:e559831a
  sync_delivery_control: |
    server.js#handleJoin and server.js#handleReconnectGrace send only identity and current scale;
    they must not call broadcastWorldSync or otherwise increment the shared sync cycle. The next
    timer-owned cycle includes the new client through the normal plan. broadcastWorldSync prepares
    one immutable encoded snapshot and replaces only the unsent portion of the previous plan.
    server.js#runSyncPhases processes the current phase until either all entries are consumed or
    SYNC.deliveryBudgetMs elapses, then yields with setImmediate; it advances phase/index only after
    the current phase is complete. Each entry is consumed exactly once. sendPlanFragment skips a
    socket whose bufferedAmount exceeds SYNC.maxSocketBufferedBytes, so that socket cannot delay
    other clients or phases. The plan's encoded strings are never rebuilt during delivery, and its
    cycle/state remain independent of input, join, reconnect, or ACK timing.  # @fix:7c4d2e91 @fix:91ab6e30
  server_performance_statistics: |
    server.js owns one module-level performanceStatistics accumulator and resets it only after reporting. In tick(), time only stepAuthoritativeWorld({ world }, inputsByClient, dt, Math.random), then add its elapsed milliseconds, increment the iteration count, and add world.fish.length + world.shreds.length after the step. broadcastWorldSync() increments preparedSyncCycleCount once, replaces any unsubmitted common phase plan while adding its remaining message count to droppedFragmentCount, and records each completed phase duration. `v:N` records cycle, sent-byte total, first-send timestamp, ACK timestamp, and socket bufferedAmount without gating any phase. The five-second report prints world iteration time, phase time, controlled object count, dropped fragments per cycle, and ACK count.  # @ds:61245206 @ds:0a2b6379 @ds:77faf734
  join_identity: |
    Join form starts with generated name and generated user color.
    It includes a paid/free toggle. The toggle is only a local domain attribute,
    not account or billing integration. User fish body fill starts from the selected
    user color, with visual overlays preserving that base color.
    The compact join message is n:${colorHexNoHash}:${base64urlName}:${u|p}.  # @ds:58050922 @ia:32288dfb @ds:5a4d3d6d
    handleJoin must not create a second user fish for a socket that already controls
    a restored user fish. If meta.fishId already points to an ownerKind='user' fish,
    update that fish's userName, userColor, and userTier from the join profile, send
    identity/world-size/absolute-sync for that same fish, and return without pushing
    a new fish into world.fish.
    Otherwise handleJoin creates exactly one user fish with ownerKind='user', userName,
    userColor, userTier, and a temporaryConnectionCode scoped to this client instance,
    then calls player.js#startUserFryStage with reason='join' so first entry begins
    at the minimum visible fry size and enters the 3 second start window.
    main.js must hide the join panel after any identity message, not only after a
    manual join submit, so an automatic reconnect cannot leave an active join form
    that creates a duplicate user fish.
    client-net.js#createClientNet owns first-communication settling for entry UI:
    when the WebSocket opens with no stored temporaryConnectionCode, call
    onInitialCommunication({ kind:'new' }); when an identity message is received
    for a reconnect or join, call onInitialCommunication({ kind:'restored' }) once
    before/with onIdentity. main.js starts with #join, #control-modes, #control-help,
    #leave-game, #joystick-panel, and #player-metrics hidden; it shows the join
    form only after first communication establishes a new session, and shows game
    controls only after joined=true.
    style.css#join uses ./assets/start.png as the entry-screen background image,
    layered under the existing dark water overlay so the form remains readable.
    This entry background is tied to the visible join panel and is independent of
    the in-game canvas background.  # @ds:58200142 @ia:3983084a
  join_presentation: |
    index.html#join-form keeps the existing #join-name text input, #join-color
    native color input, #join-tier paid identity input, and submit event. Build
    the English card with the project logo, the fixed entry copy, a compact fish
    color row, and two same-name radio labels: free radio checked by default and
    paid radio retaining id #join-tier. The color row uses an object element loading
    ./assets/fish2.svg, retaining the full gameplay fish geometry. Make the row its
    only rounded outline: use a 64px transparent preview area on the row's palette-
    consistent deep-blue background, a three-column grid (preview, copy, picker),
    and one .join-colour-swatch div. Position #join-color as a full-size, invisible
    native input over that div so it remains the system color-dialog trigger; CSS
    draws only the div background and its 2px ring. main.js#syncJoinFishPreview
    derives a luminance-aware --join-swatch-ring and writes --join-swatch-color from
    #join-color.value at initialization and on color input: use a light ring for
    dark colors and a dark ring for light colors. The same function writes the
    color into the loaded fish SVG root after the object load event. In that load handler inject a
    1.396s infinite, ease-in-out CSS cycle for fin_back, fin_bottom,
    fin_bottom_small, and fin_bottom_top. fin_back rotates around its 0% horizontal
    bounding-box edge (the body join), while the other fins retain their calm cruise
    scale/skew equivalents; do not modify simulation state. Their labels provide
    the fixed Free/Paid eligibility text. CSS
    On .join-corner-decoration object load, inject independent 5.2s and 6.4s
    ease-in-out alternate rotations for the SVG's two path layers around the shared
    viewBox center, with amplitudes <= 2deg and no pointer interaction. Render the
    header logo with an object loading ./src/selfish-bait.svg instead of an img. On
    its load, define one main.js#JOIN_LOGO_LIVELINESS constant holding the rotation
    amplitude and timing scale. Use it to inject independent 2.7s, 3.1s, 3.55s,
    2.9s, and 3.35s ease-in-out alternate rotations for its five path layers around
    the 39x39 viewBox center, with a 3.4deg base amplitude and no pointer interaction.
    CSS gives
    Free a teal-green selected border/fill/marker and Paid a violet-pink
    selected border/fill/marker; native radio inputs remain accessible while
    visually hidden.
    Add ./assets/join-corner-decoration.svg as a clipped, pointer-inert,
    semi-transparent top-right layer inside #join-form. CSS keeps #join as the
    full-screen start.png scene with a left-side readability overlay, makes one
    translucent 420px maximum-width entry card, and scopes all join styling to
    #join / #join-form so the in-game HUD is unaffected.  # @ds:277a51d7
  reconnect_and_timeout: |
    On unexpected socket break, keep the user fish as ownerKind='user' for 3 seconds.
    During the grace window, continue the last input action.
    If the same temporaryConnectionCode reconnects in time, restore control by setting
    fish.clientId to the new socket clientId, setting meta.fishId to fish.id, preserving
    the existing temporaryConnectionCode, deleting the pending disconnect entry, and
    sending identity/world-size/absolute-sync for that same fish.
    A successful reconnect must leave exactly one ownerKind='user' fish for that
    temporaryConnectionCode and client instance.
    If a reconnect message cannot restore an ownerKind='user' fish inside the grace
    window, the server must send an explicit reconnect-failed event for that socket.
    client-net.js must treat reconnect failure as leaving the joined state: clear
    currentUserFishId, temporaryConnectionCode, and sessionStorage fish.connectionCode,
    stop sending input/idle messages, and notify main.js so the join panel is visible.
    Reconnect failure also settles first communication as kind='new' when the entry
    UI is still pending, so a page reload with an expired stored code transitions
    directly from pending to the join form without a transient joined/control UI.
    main.js must not choose a followed fish by stale id when currentUserFishId no
    longer points to an ownerKind='user' fish in the latest snapshot.
    Otherwise convert the fish to ownerKind='npc', npcRole='abandoned-user-fish',
    remove userName and userTier, keep formerUserColor, reset age to 0 so the
    abandoned fish starts a fresh NPC lifetime, and apply abandoned gradient.  # @ds:93a64773 @ds:eba75588 @ds:a6c9e8b4
  explicit_leave: |
    handleLeaveGame first calls isLeaveBlockedByUserAttack.
    If blocked, server rejects the leave command and fish remains user-owned.
    If allowed, convert immediately to NPC without the 3 second grace.  # @ds:704ab317 @ds:8917ad63
  player_lifecycle: |
    player.js owns user-fish fry and lifetime helpers.
    startUserFryStage(fish, position, reason):
      - preserves fish.id, clientId, temporaryConnectionCode, userName, userColor,
        and userTier;
      - sets ownerKind='user', isPlayer=true, npcRole=null, pos=position, vel=0,
        mode='cruise', size=PLAYER.fryStartSize, radius=radiusOf(size),
        fryAge=0, nominalStartSize=PLAYER.startSize, playerActiveAge=0, age=0,
        feedingSuccessFactor=1, feedingCooldown=0;
      - leaves the same object in world.fish so existing client control binding
        remains attached to the same id.
    advancePlayerLifecycle(world, dt, rng):
      - for every ownerKind='user' fish, if fryAge is active, advance it toward
        PLAYER.fryGrowthSeconds=3 and reset playerActiveAge to 0 while the start
        window is active;
      - while fryAge is active and fish.size is below PLAYER.startSize, interpolate
        start growth from PLAYER.fryStartSize to PLAYER.startSize using the fryAge
        ratio and clamp size to PLAYER.startSize; if feeding raises size to
        PLAYER.startSize or above before 3 seconds, leave that larger current
        size intact and keep fryAge active for protection until the timer expires;
      - when fryAge reaches PLAYER.fryGrowthSeconds, clear fryAge and start active
        lifetime counting from playerActiveAge=0;
      - when fryAge is not active, increment playerActiveAge by dt;
      - when playerActiveAge reaches PLAYER.maxLifetimeSeconds, call
        expireOldUserFish(world, fish, rng).
    expireOldUserFish(world, fish, rng):
      - copy the user identity fields and current fish id;
      - call spawnShredsFromFish(world, fish, rng) before resetting the body;
      - compute old-age respawn position as the average position of the shreds
        returned by spawnShredsFromFish, falling back to the dead fish position if
        no shred was created because of the controlled-object limit;
      - restart the same fish object with startUserFryStage(reason='oldAge') at
        that cloud center.
    stepAuthoritativeWorld must call advancePlayerLifecycle after fish integration
    and before feeding resolution, so expired user bodies create shreds and re-enter
    the world as protected fry in the same authoritative tick.  # @ds:4c7a2b91 @ds:c18e5b42 @ds:9d62f0a7 @ds:b7a4c391 @ds:e13d7a52
  player_lifetime_ui: |
    protocol.js includes user fish start-window age and playerActiveAge in fish row state mods as
    `gN` and `lN`, where N is age in tenths of a second clamped to a non-negative
    integer. stateMods emits `gN` while ownerKind='user' and fryAge is active,
    and emits `lN` for ownerKind='user'. parseFishRow reads `gN` into
    parsed.fryAge = N / 10, clears fryAge to null when `gN` is absent on a user
    row, reads `lN` into parsed.playerActiveAge = N / 10, and preserves the
    previous active age when `lN` is absent.
    index.html contains #player-metrics as a fixed top-center UI group. It holds
    #player-size with nested #player-size-label and #player-size-value, plus
    #lifetime, so the current user fish size stays next to the active lifetime
    indicator instead of being mixed into the top-left HUD.
    style.css#player-metrics makes the group noticeable and keeps pointer-events
    disabled; #lifetime is wider and thicker than the old compact HUD bar and
    remains centered in that group under the top HUD/debug controls.
    main.js#updatePlayerLifetimeBar(fish):
      - when no current user fish exists, reset the bar to empty;
      - keep #player-metrics hidden unless a current ownerKind='user' fish exists
        and the joined entry UI has been resolved;
      - read activeAge = max(0, fish.playerActiveAge || 0);
      - ratio = clamp(1 - activeAge / PLAYER.maxLifetimeSeconds, 0, 1);
      - set #lifetime-bar scaleX to ratio;
      - use the start-window color only when activeAge is 0 and fish.fryAge is
        active in the parsed snapshot;
      - otherwise compute remainingSeconds = PLAYER.maxLifetimeSeconds - activeAge;
        set the active bar color red when remainingSeconds < 3, yellow when
        remainingSeconds < 10, and the ordinary active color otherwise.
    main.js must not infer lifetime progress from local performance.now(), fish
    size drops, or PLAYER.fryGrowthSeconds. The bug mechanism was local
    size/time heuristics drifting from server lifetime and hiding changes to
    PLAYER.maxLifetimeSeconds.  # @ds:2e91f6d4
  player_size_ui: |
    main.js#updatePlayerSizeMetric(fish) owns #player-size-value text. It displays
    the synchronized current user fish size with one decimal place and displays "-"
    when there is no current user fish, while the #player-metrics container remains
    hidden in that state. style.css keeps #player-size-value as the dominant
    high-contrast number and #player-size-label as secondary text. frame() calls
    it with the same current user fish used for the lifetime bar so both
    top-center metrics update together from the latest client snapshot.  # @ds:b9136c2e
  player_speed_mode_ui: |
    index.html contains #player-speed-metric outside #player-metrics so it can move
    between the visual joystick area and the bottom-right viewport corner.
    main.js#updatePlayerSpeedMetric(fish):
      - compute realSpeed from the synchronized current user fish velocity;
      - treat speed as displayable only when it rounds to a non-zero two-decimal value;
      - compute maximum possible user-fish speed as maxSpeedOf(fish.size, 'user') * 0.99;
      - compute the integer speed percent as round(realSpeed / maximumPossibleSpeed * 100), clamped to 1..99;
      - write the percent integer and the real speed with two decimals into the metric;
      - set the percent color to green when fish.mode is cruise;
      - when fish.mode is burst, set the percent color from a low-speed green-pink to a high-speed pink-red based on the displayed percent;
      - add a joystick placement class when the joystick panel is visible, otherwise use the bottom-right placement;
      - fade the whole metric in for displayable speed and fade it out when speed is zero, no current user fish exists, or the joined UI is not active.
    style.css#player-speed-metric uses the same font size as #player-size-value for the main percent number and keeps pointer-events disabled.  # @ds:c656f0ec
  game_menu_ui: |
    index.html contains #game-menu-toggle as a top-left three-bar icon button and #game-menu as the opened menu panel.
    #game-menu contains #control-modes, #app-version, #debug-mode-toggle, #leave-game, and #control-help.
    main.js owns gameMenuOpen and toggles #game-menu from #game-menu-toggle without changing world state or input state.
    showAppVersion writes the version text into #app-version inside #game-menu.
    setupControlModes keeps the joystick, pointer, and touch screen-mode buttons inside #game-menu and updates #control-help whenever the active screen mode changes. Keyboard is not a selectable screen mode because it remains active in every mode.
    updateControlHelp writes mode-specific help:
      - keyboard/default: movement keys and Space/1/2/3 speed levels 31/65/99 remain active with the visible joystick screen input;
      - pointer: experimental pointer movement and mouse-hold v31 while keyboard stays active;
      - touch: experimental primary touch around the user fish controls direction and speed v=0..99 while keyboard stays active;
      - joystick: visible lower-right radial joystick controls direction and speed v=0..99 while keyboard stays active.
    #debug-mode-toggle toggles only debugMode and does not own menu visibility.
    #leave-game remains the explicit leave/enter command inside the menu and keeps the same joined-state behavior.  # @ds:ab1e4f02 @ds:8d13f6a2 @ds:59c118f5 @ds:70871bc5 @ds:fb11044e @ds:22fd3ab4
  world_map_ui: |
    index.html contains #world-map-toggle in the top-right of #hud and #world-map as a screen-space 200x200 px overlay. The map button is visible only while an active joined session exists, has the same toolbar button footprint as #game-menu-toggle, and independently toggles worldMapVisible without changing debugMode, world state, input, or socket messages. #world-map is hidden unless worldMapVisible is true. In every responsive breakpoint, #hud .hud-row keeps explicit left-button, shrinkable metrics, and right-button grid tracks; #world-map-toggle uses the same breakpoint-specific width, height, border radius, and visual container as #game-menu-toggle, so neither button can wrap below the toolbar.  # @ds:3a980720
    constants.js exports WORLD_MAP with the fixed 200px square size, 12px left inset, and 12px overlay gap; do not reuse DEBUG minimap coordinates for player-facing map UI. main.js#getWorldMapTop reads #hud and visible #player-metrics bounding rectangles every animation frame, takes the greater bottom edge, and adds WORLD_MAP.overlayGapPx. Pass this screen-space top coordinate in the render state. render.js#drawWorldMap(ctx, world, currentUserFishId, top) runs after restoring the viewport transform, uses WORLD_MAP.sizePx and WORLD_MAP.leftPx with the supplied top coordinate, validates positive world dimensions, draws the fixed square frame, and maps each canonical fish position into the square using clamped float coordinates without mutating fish.pos. NPC point diameter is derived from linear size sqrt(max(0, fish.size)): nominal PLAYER.startSize maps to 2px, every smaller value also maps to 2px, and the largest current fish maps to 5px; clamp the final diameter to [2, 5] and handle the no-range case without division by zero. Other user fish use a 3px inner point plus a 1px-gap, 1px-stroke outer circle; the current user uses a 5px inner point plus a 1px-gap, 2px-stroke outer circle. Keep the fish color resolution used by the existing minimap.  # @ds:3a980720 @ds:8f2c91ad
  world_snapshot_info_ui: |
    index.html contains #world-info in the bottom-left overlay layer. It has six
    value spans: #world-fish-count, #world-fish-area, #world-nutrient-count,
    #world-nutrient-area, #world-scale, and #world-sync. The Scale value shows
    world.scale. The Sync value shows the latest received sync cycle and the
    rolling average number of distinct received quadrants per iteration over the
    last 20 completed cycles.
    main.js#updateWorldSnapshotInfo(world) reads only the latest world object
    stored from WebSocket synchronization, not extrapolated render-only bubbles
    or server-only state:
      - fishCount = world.fish.length;
      - fishArea = sum(Math.PI * fish.radius^2) for finite synchronized fish radii;
      - nutrientCount = world.shreds.length;
      - nutrientArea = sum(shred.geometricArea) for finite synchronized shreds.
    style.css#world-info anchors the panel at bottom left, uses a compact
    translucent background, and leaves pointer-events disabled.  # @ds:e42a7c19
  join_after_leave: |
    main.js owns the local entry/game UI state.
    setJoinedUiState(joined) hides the join panel and labels #leave-game as
    "Выйти" while joined=true; it labels the same HUD command as "Войти" while
    joined=false without automatically opening the form. handleLeaveGameButton
    calls client-net.js#leave when joined=true. When joined=false, it opens the
    join panel with the existing draft name, color, and paid/free fields intact.
    setJoinedUiState also owns visibility for entry chrome: before first
    communication, keep the join form, leave command, control mode row, hint,
    joystick panel, and player metrics hidden; when the join form is visible,
    keep fish controls and player metrics hidden; when joined=true, show the fish
    control row and hint, and let joystick visibility follow the active control
    mode.
    client-net.js#leave sends the compact leave request but keeps the current
    session binding until the server confirms success. On event npc for the
    currently controlled fish, confirmLeaveSucceeded clears currentUserFishId,
    temporaryConnectionCode, sessionStorage fish.connectionCode, and joined.
    main.js then calls setJoinedUiState(false) and shows the join panel. On event
    wrn, keep the joined state and leave button label unchanged because the
    server denied the explicit leave.  # @ds:9772e9ac @ds:fb11044e @ds:704ab317 @ds:8917ad63
  world_scale: |
    WORLD has fixed technical width=500, height=500, cellSize=100, pixelsPerWorldUnit=4, and userAreaSideDiameters=10. FISH owns nominalStartDiameter=8 normalized units; size=1 is dimensionless and changes diameter by sqrt(size). world.js#makeWorld always uses the fixed technical dimensions. world.js#effectiveWorldArea(userCount) returns (500*4)^2 + userCount*(10*8*4)^2 in player-facing pixel area. world.js#worldScale(userCount) returns sqrt(effectiveWorldArea/(2000*2000)), rounded to three decimals. Convert a player-facing pixel length to technical coordinates as pixelLength / pixelsPerWorldUnit / world.scale. Do not rescale canonical pos values when the count changes.
    fish.js#radiusOf returns the base pixel radius and fish.js#technicalRadiusOf applies both conversion layers for server/client collision geometry. Keep speed and acceleration tuning in px/s and px/s² and convert at the simulation boundary; keep time, probabilities, damping rates, and dimensionless size values unchanged. targetNpcCount(world) uses effectiveWorldArea(world.userCount) rather than width*height. server.js sends `s:<formatted scale>` after identity/reconnect and broadcasts it whenever user count changes. The formatter removes insignificant trailing zeroes. render.js changes only the projection factor, uses the same factor in both viewport transforms, and never recreates the Canvas.  # @ds:10dc892b @ds:8b998807 @ds:6ca3cb74 @ds:915ab0e4 @ds:2595a2d
  client_pixel_decor: |
    main.js owns clientBubbles and clientBubbleEmitters. world.js#makeBubble and fish.js#makeExhaleBubble create decor records with only `posPx`, `velPx`, `radiusPx`, `targetRadiusPx`, age, lifetime, alpha and phase; derive fish size exclusively from `FISH.nominalStartDiameter * WORLD.pixelsPerWorldUnit * sqrt(size) / 2`, never from technical `fish.radius`. world.js#advanceBubbles mutates only pixel positions, pixel velocities and pixel radii; it uses pixel world bounds and does not read or apply world.scale. fish.js exhale displacement uses `posPx` and pixel mouth coordinates. render.js#buildToroidalRenderWorld must not contain or project decor; render.js#drawPixelBubbles may map pixel decor to screen coordinates only for the current draw call and must style it with screen-pixel values such as `BUBBLE.strokeWidthPx`, never with technical radii or a technical-unit minimum line width. A worldScale message therefore changes only the transient render projection, not any existing decor radius, speed, position, trajectory or styling values.  # @ds:d6cebf86 @ia:3c4d5e6f @fn:a9a3ed12
  visual_layer_matrix: |
    render.js owns a client-only `renderLayer` assignment cache and never writes layers into synchronized fish, shred or world state. `assignFishRenderLayers(fish)` sorts visible fish deterministically and assigns even layers: NPC fish use 100..9000 and user fish use 10002..29000, with user layers always higher. `renderLayerForBubble(bubble, fishLayers)` resolves `bubble.sourceFishId` to the source fish layer and returns `fishLayer - 1`; makeBubble and makeExhaleBubble must preserve that source id. `assignShredRenderLayers(shreds, occupiedFishLayers)` creates only odd candidates derived from occupied fish layers, distributes shreds deterministically and evenly across those candidates, and may use at most five extra fish slots; it must not use empty layer ranges. render.js builds one render-item list for fish, shreds and bubbles, sorts ascending by renderLayer and draws it in that order, so a bubble is under its source fish while shreds can cover any fish. `drawPixelBubbles` is folded into this ordered pass; its radius and stroke remain screen-pixel styling and only its transient position is projected. CSS background/parallax remains outside the gameplay canvas and below all gameplay items; lower `BACKGROUND.parallaxFactor` remains farther back. Layer values never enter physics, collision, protocol or synchronized state.  # @ds:7c2f91ad @ds:e13d7a52 @ds:d6cebf86
  phased_spatial_sync: |
    protocol.js#encodeWorldCycle serializes only non-empty cell rows and indexes only those ranges. It also returns an empty-cell boolean lookup for all 25 coordinates. Prebuild coordinate-specific empty payload templates with the one-byte delta marker for horizontal neighbors only; at send time interpolate only the current cycle number and choose the absolute or relative header. The central cell is sent when non-empty, and empty placeholders are sent only for the left and right phases. Empty cells in vertical, diagonal, and remaining phases are omitted from the common plan.
    server.js#broadcastWorldSync creates one common plan for cycle N. For every live user socket, resolve its wrapped cell and add messages in phases: own; left and right; top and bottom; then top-left, bottom-left, top-right, bottom-right. Run each phase across all sockets before scheduling the next phase with setImmediate. A socket send only skips that socket when it is closed; it never blocks phase advancement. Starting N+1 cancels the remaining scheduled plan and counts its unsent entries. Do not allocate per-client queues or sort cells by distance. client-net.js sends `v:N` once after receiving any three fragments of N; server.js#handleSyncAck logs it with recorded sent bytes and timestamps only.  # @ds:e559831a @ds:c39827ed @ds:682570c7 @ds:77faf734 @ds:0a2b6379
  wrap_position: |
    function wrapPosition(fish, world){
      fish.pos.x = ((fish.pos.x % world.width) + world.width) % world.width
      fish.pos.y = ((fish.pos.y % world.height) + world.height) % world.height
    }
    Velocity is not reflected or stopped.  # @ds:c83f4c1e
  density_spawn: |
    targetNpcCount = floor(world.width * world.height * WORLD.npcDensity)
    findLowestDensitySpawn samples candidate cells/points and scores each by
    distance-weighted count of all fish plus shreds. Use the lowest
    score for NPC spawn and user respawn. Density includes user fish, NPC fish,
    and persistent shreds.  # @ds:53db39eb @ds:e13d7a52
  world_background_tile_parallax: |
    CSS owns the in-game background stack. style.css#body::before draws
    ./assets/back.png as a repeated fixed layer under the transparent canvas;
    style.css#body::after draws the viewport-space haze gradient above the tile
    and below all gameplay/UI layers. style.css#game must not paint an opaque
    background. render(ctx,state) clears the canvas with clearRect at the start of
    each frame instead of painting the background.
    render.js#updateWorldBackgroundCss(world, followed) updates CSS variables
    --world-bg-x and --world-bg-y on document.documentElement. It owns a render-only
    accumulated background phase in CSS pixels. render.js#backgroundCameraDelta
    computes the nearest toroidal delta from the previous camera focus to the
    current canonical focus; if the followed fish or world dimensions change,
    reset only the reference focus and keep the current CSS phase unchanged.
    Each frame subtracts delta * viewportScale * BACKGROUND.parallaxFactor from
    the phase and wraps the phase to a bounded pixel range before assigning the
    CSS variables. This prevents visible jumps on world-edge wrapping, reconnects,
    first snapshots, and followed-fish switches while keeping all state render-only.
    The background variables must not mutate world, fish, viewport, sync buffers,
    or input state.
    # @ds:2b3e71e0 @ds:a43de7ec @fix:4bbc0692 @ia:3983084a
  controlled_objects: |
    world.js owns controlled-object helper functions. controlledObjectCount(world)
    returns (world.fish?.length || 0) + (world.shreds?.length || 0), because these
    are the server-owned entities encoded into world sync rows. It excludes client
    decor, local bubbles, exhale state, debug traces, labels, and any other render
    only arrays. canAddControlledObjects(world, addedCount) compares the resulting
    count with WORLD.maxControlledObjects. isOldAgeSuspended(world) returns true
    only when WORLD.maxControlledObjects is finite and positive and
    controlledObjectCount(world) / WORLD.maxControlledObjects > WORLD.oldAgeSuspendFillRatio.
    # @ds:eccfca7e @ds:d140effd
  npc_spawn_and_growth: |
    maintainPopulation compares current ownerKind='npc' count to targetNpcCount.
    New NPC fish spawn at safe lowest-density areas as fry:
      size starts at FRY.startSize
      nominalStartSize = sampleSize(rng)
      fryAge increases for 10 seconds
      size interpolates to nominalStartSize during those 10 seconds
    findSafeNpcSpawn(world, nominalStartSize, rng) must wrap-aware sample candidate
    positions, score density over all fish, then reject candidates whose actual
    spawn-state fry circle at FRY.startSize is already inside or immediately
    entering any fish attack zone. The attack-zone rejection must use current fish
    positions, radii, burst-capable reach, mouth/head direction, relative motion
    where available, and the fact that the fry is edible while it grows. A safe
    candidate must provide at least a short lead time before first attack contact
    so the fry can execute ordinary NPC intent selection on the next server step.
    If all candidates are risky, choose the candidate with the largest estimated
    time-to-attack-contact and lowest density as fallback, while still preferring
    candidates outside immediate overlap/attack reach. maintainPopulation passes
    the chosen position into makeFish and assigns NPC courage before adding the
    fish to world.fish.
    New NPC courage is assigned by assignNpcCourage(world,rng): every tenth NPC
    spawn uses a uniform 0..100 value; otherwise use current live-NPC average
    courage or 50 when none exists, add random +/-10, then clamp to 0..100.
    After fry growth completes, further growth only comes from eating.  # @ds:e6ecfbdd @ds:7ba4084c @ds:e29aeb93
  npc_risk_aware_hunt: |
    prey.js owns chooseNpcIntent(self, world, rng, dt) before wander/flee output is
    committed for a NPC. It computes nearest threat able to eat self, selected prey
    able to be eaten by self, estimated incoming attack-contact time, estimated own
    attack-contact time, and expected post-eat size via fish.js#growSizeFromAreas
    without mutating self. If post-eat size would break the current threat's
    isEdibleBySize before incoming attack contact, keep pursuit. If the threat
    would still be able to eat self or reaches attack contact first, compare
    self.courage against a random 0..100 roll to choose pursuit vs flee. Flee uses
    a separation trajectory that maximizes distance from the attacker, not merely
    the opposite of the current target direction.
    Potential threats are any fish that can eat self by isEdibleBySize and
    canBeVictimOf, independent of current mode. Threat selection and danger scoring
    must use nearestToroidalDelta so edge wrapping does not hide predators.  # @ds:d0ef4576 @ds:e29aeb93 @ds:d867989f @ds:98224ab9 @ds:92d5b0c1
  npc_danger_aware_steering: |
    prey.js owns danger-aware steering helpers used by chooseNpcIntent:
      - potentialThreatsFor(self, world) returns all fish other than self that can
        eat self by predation size/type, independent of mode.
      - chooseDangerAwareDirection(self, world, baseDirection, mode, dt, rng)
        samples candidate directions and returns the lowest-danger normalized vector.
        For mode='hunt', candidate directions span +/- NPC.huntDangerCorrectionDeg
        around baseDirection toward the selected prey. For mode='flee', candidate
        directions cover the full circle.
      - dangerScoreForDirection(self, direction, threats, world) projects self along
        direction by NPC.dangerProjectionDistancePx and scores each threat by the
        projected path's distance to contact and attack reach. Use self.radius and
        threat.radius in every contact/reach calculation; never score only centers.
      - smoothNpcSteering(self, targetDirection, targetAccel, dt) stores
        self.steerDecision and applies NPC.maxTurnRateDegPerSecond and
        NPC.accelResponsePerSecond so direction and acceleration change gradually.
    chooseNpcIntent calls chooseDangerAwareDirection in pursuit and flee branches:
      - pursuit uses the direction toward selected prey as baseDirection and limits
        correction to the hunt angle;
      - flee passes no baseDirection and may select any direction around the NPC.
    The ordinary wander branch also passes its desired heading through
    smoothNpcSteering so random wander turns do not snap direction or acceleration.
    The final acceleration returned to stepAuthoritativeWorld comes from
    smoothNpcSteering and uses the branch magnitude: PREY.wanderAccel for wander,
    PREY.fleeAccel for hunt and flee.  # @ds:92d5b0c1 @ds:7cb92a44 @ds:4f58a1cd @ds:c6d7e8f9 @ia:8a4b2f19
  npc_continuous_motion_and_lifetime: |
    chooseNpcIntent must return an active movement intent for every live NPC on
    every authoritative tick. If no threat and no prey target is selected, use
    wanderIntent; wanderSteer keeps an existing heading until a random turn event
    replaces it, so ordinary NPCs keep a cruising goal instead of becoming idle.
    prey.js#expireOldNpcFish(world,rng) runs after NPC integration and before
    predation resolution. It first checks world.js#isOldAgeSuspended(world). When
    old-age is suspended, keep all NPC fish in world.fish and leave their current
    age values intact. When old-age is active, remove ownerKind='npc' fish whose
    age is at least NPC.maxLifetimeSeconds, call spawnShredsFromFish for each
    removed fish, and do not call grow(), increment eatenFishCount, or emit a
    predation victim row.
    # @ds:b47c2d91 @ds:a6c9e8b4 @ds:e13d7a52 @ds:d140effd
  shreds: |
    shred.js owns shred creation, drift, contact eligibility, layer consumption,
    and nutrition math. makeWorld initializes shreds=[] and nextShredId=1.
    spawnShredsFromFish(world, fish, rng):
      - compute dead fish canonical circular area as Math.PI * fish.radius^2;
      - compute total shred geometric area = deadArea * SHRED.areaRatio;
      - derive the configurable visual diameter bounds from the nominal start-fish
        diameter multiplied by SHRED.minDiameterRatio/maxDiameterRatio, independent
        of PREY.minSize; sample within those bounds with
        SHRED.fragmentation/sizeJitter, convert the sampled visual diameter once to
        technical units using WORLD.pixelsPerWorldUnit and world.scale, convert to
        circle area, clamp the final piece to remaining area, and derive shred.size
        from that technical area;
      - place each shred at a random polar offset within min(fish.radius,
        fish.radius * SHRED.scatterRadiusRatio) around fish.pos and wrap it;
      - sourceColor = fish.formerUserColor for npcRole='abandoned-user-fish' when
        present, otherwise fish.userColor when present, otherwise the rendered NPC
        hue color converted to a CSS hsl string;
      - before pushing each shred, ensure canAddControlledObjects(world, 1) is true;
        if the limit is reached, stop adding further shreds and leave any remaining
        geometric area unspawned;
      - set remainingLayers to the ordered layer ids from shred.dsc, decayAge=0,
        drag to a random value in SHRED.dragMin..SHRED.dragMax, visualSeed=rng(),
        velocity to a random direction and speed in SHRED.initialSpeedMin..initialSpeedMax.
      - return an array of the shreds actually created so player old-age respawn
        can place the new fry at the center of its predecessor cloud.
    advanceShreds(world, dt):
      - for each shred, inspect nearby moving fish with nearestToroidalDelta; when
        a fish is within SHRED.wakeRadiusRatio * (fish.radius + shred.radius), add
        a small dt-scaled velocity impulse along the fish velocity, weighted by
        speed and squared proximity falloff;
      - damp velocity with exponential drag exp(-shred.drag * dt), using tuned
        SHRED.dragMin..SHRED.dragMax values that leave visible drift after passing
        fish influence;
      - clamp tiny speed below SHRED.restSpeed to zero, integrate pos += vel*dt,
        and wrap by world bounds.
      - update world.shredDensityLimit toward SHRED.densityLimitBase using
        SHRED.densityLimitSmoothRate and dt;
      - after movement, advance each shred's decayAge by dt. For each full
        SHRED.decayIntervalSeconds interval, compute current shred density from
        world.shreds against world area. If density is below world.shredDensityLimit,
        keep the current layers and defer the next check by one full interval. If
        density is at or above the limit, remove the next layer group in
        SHRED.layerOrder. If the next group is the final 10%+10% group, remove the
        whole shred from world.shreds instead of leaving an empty layer set. Do not
        grant nutrition, increment fish counters, or play mouth cues from decay.
    canEatShred(fish, shred, world):
      - speed = hypot(fish.vel.x, fish.vel.y) must be >= SHRED.minFeedingSpeed;
      - fish visual diameter `(fish.radius * 2)` must be >= shred.size * SHRED.eatSizeRatio;
      - circle contact uses nearestToroidalDelta and radius sum fish.radius +
        shred.radius, where shred.radius = shred.size / 2.
    shredCandidateNutrition(fish, shred):
      - inspect the next layer group from remainingLayers in order: first 30%,
        second 30%, 20%, then both final 10% layers as one group;
      - layerFraction is the sum of that group;
      - swallowedArea = shred.geometricArea * layerFraction;
      - baseNutrition = swallowedArea * SHRED.nutritionMultiplier;
      - color factor = 1.0 for common layers; for the first two 30% layers use
        1.0 when normalized colors match, otherwise compute HSV similarity as
        hueWeight*hueSimilarity + saturationWeight*saturationSimilarity and map
        it to SHRED.colorFactorMin..SHRED.colorFactorMaxDifferent;
      - return { group, swallowedArea, nutrition } without mutating fish or shred.
    consumeShredLayer(fish, shred, group):
      - call refreshShredDecay(shred) before or after removing layers; refresh sets
        decayAge=0 and does not restore any missing layers;
      - remove group layers from shred.remainingLayers;
      - increment a protocol-visible fish.shredEatCueCounter integer for every
        consumed layer, including burst-state feeding, so clients can play the
        0.3s mouth cue;
      - predation.js removes the shred from world.shreds when no layers remain.
    refreshShredDecay(shred) must also be called when a fish interaction reaches
    shred candidate handling but the random feeding attempt fails or the candidate
    is later rejected during refresh. This keeps any successful or unsuccessful
    feeding interaction from losing already-decayed state while postponing the next
    automatic decay interval.
    Protocol sync must include every live shred in each world snapshot. Shred
    rows are independent from fish rows, so fish tombstone rows keep their current
    meaning. A full `s` row includes static fields plus decayAge; a dynamic `d`
    row includes the known shred id, position, motion, decayAge, and `=` or a new
    layers mask. `applyWorldSync` rebuilds the shred array from all parsed rows of
    the message, so an omitted id is removed even from a delta message. Client
    render draws only remaining SVG layers from the published web-canvas/assets/
    shred.svg runtime copy of the canonical ds/assets/shred.svg asset and treats
    layer drift as render-only.
    # @ds:e13d7a52 @ds:7c2f91ad @ds:918d4b63 @ds:d5e7a01c @ds:8b62d9ce @ds:c14f7a08 @ds:9e4c1b7a @ds:b6f08d21 @ds:4d7c2e93 @ds:f0a6c5d8 @ds:a2d5936f @ds:ed2b4f19 @ds:d3187816 @ds:31a8f5c2 @ds:fb0f32c4 @ds:eccfca7e @ds:9f50b1be
  feeding_batch: |
    fish.js#makeFish initializes feedingSuccessFactor=1 and feedingCooldown=0.
    fish.js#advanceFeedingState(fish, dt) runs once per authoritative tick before
    feeding resolution: feedingCooldown=max(0, feedingCooldown-dt) and
    feedingSuccessFactor=min(1, feedingSuccessFactor + dt / PREDATION.feedingRecoverySeconds).
    predation.js owns resolveFeedingBatches(world,rng), called after fish movement,
    shred drift, and old-age expiry, before maintainPopulation.
    resolveFeedingBatches iterates over a snapshot of world.fish in current order;
    skip a feeder if it is no longer in world.fish or feedingCooldown>0.
    collectFeedingCandidates(feeder, world):
      - fish candidates: every other fish still in world.fish for which canEat
        is true using isAttackContact, size threshold, user-tier eligibility, and
        burst mode; when feeder has active user fryAge, user-fish victims are
        skipped even if size/tier would otherwise pass; nutrition = victim.size *
        GROWTH.fishAreaGainRatio; swallowedArea = victim.size.
      - shred candidates: every shred for which canEatShred is true; use
        shredCandidateNutrition to obtain nutrition and swallowedArea for the next
        layer group.
      - sort descending by nutrition; for equal nutrition keep collection order.
    processFeedingBatch(feeder,candidates,world,rng):
      - if candidates is empty, do nothing and do not start cooldown;
      - capacity = feeder.size, because fish.size is normalized canonical circle
        area from fish.geometry.collision-area;
      - activeFactor = min(feeder.feedingSuccessFactor ?? 1, first candidate is
        shred ? PREDATION.shredStartSuccessFactor : 1);
      - for each candidate in order, first discard it if the candidate object is
        no longer present or no longer eligible;
      - if swallowedArea would make successfulArea + swallowedArea > capacity,
        end the series immediately without attempting that candidate;
      - attempt succeeds when rng() < activeFactor;
      - after every attempted candidate, multiply activeFactor by
        PREDATION.fishFeedingSuccessDecayFactor for fish candidates or
        PREDATION.shredFeedingSuccessDecayFactor for shred candidates, then set
        feeder.feedingSuccessFactor = activeFactor;
      - after every attempted shred candidate, call refreshShredDecay on that
        shred regardless of success;
      - on successful fish candidate, call grow(feeder, victim.size), increment
        eatenFishCount through grow(), and remove/respawn the victim exactly as
        predation.effect and predation.player-respawn require; user victims keep
        the same fish id and enter the 3 second player start window at the
        respawn placement.
      - on successful shred candidate, call growFromNutrient(feeder,nutrition),
        consumeShredLayer(feeder,shred,group), remove exhausted shreds, and do not
        increment eatenFishCount;
      - track successfulArea only for successful attempts.
      - when at least one candidate was attempted, set feeder.feedingCooldown to
        PREDATION.feedingCooldownSeconds.
    Remove the old independent resolveShredEating pass; fish and shreds are
    considered together in this one sorted batch so larger expected nutrition
    wins the earlier attempt.  # @ds:9b41d2ac @ds:6c80e3b4 @ds:f2ad71c9 @ds:a8f03d2e @ds:4e2a91f0 @ds:e9fb3705 @ds:75a5aa4f @ds:d867989f @ds:b024b514 @ia:0bdc556b @ds:c14f7a08 @ds:9e4c1b7a @ds:b6f08d21 @ds:4d7c2e93 @ds:f0a6c5d8 @ds:3ad65f20 @ds:a2d5936f @ds:ed2b4f19
  movement_and_energy: |
    integrate treats fish.speedLevel as a target thrust level, not as an instant actual-speed assignment. speedLevel 0 applies no active thrust and lets current velocity decay through drag. speedLevel 1..30 uses maxSpeedOf(size, ownerKind) * speedLevel/100 * REGIME.cruiseFactor, where REGIME.cruiseFactor is 0.61. speedLevel 31..99 uses maxSpeedOf(size, ownerKind) * speedLevel/100. mode is derived from speedLevel: burst for >=31, cruise otherwise.
    In fish.js#integrate, record previous actual speed before adding acceleration. When active thrust is present, add acceleration, then clamp only upward acceleration: if actual speed exceeds the current target cap because the target speed decreased, preserve that higher previous speed and let applyDrag reduce it. If active thrust would raise speed beyond max(previousActualSpeed,currentTargetCap), clamp to that allowed speed. This gives all fish inertial burst ramp-up and drag-only braking without adding protocol fields.
    fish.js builds BURST_ENDURANCE_SIZE_THRESHOLDS at module initialization for speed levels 31..99; levels 1..30 are always available and have threshold 0. For each burst level, simulate continuous burst movement in REGIME.enduranceSimulationStepSeconds increments for REGIME.enduranceReserveSeconds using the same speed cap and size-loss formula as runtime spendEnergy, with speed recomputed after each size decrease. availableSpeedLevelForSize(size, desiredLevel) returns desired levels 0..30 unchanged, returns level 31 for any requested burst level when no higher threshold is available, and otherwise the nearest available level not greater than desiredLevel.
    applyDrag is linear damping.
    maxSpeedOf(size, ownerKind) computes a water-drag speed cap from fish area, then applies a predator hunt floor, not a fleeing-prey floor:
      - treat fish.size as area and derive linearSize=max(FISH.minLinearSpeedSize, sqrt(size));
      - compute the raw cap as FISH.baseNoDragSpeed / (1 + FISH.waterDragByLinearSize * (linearSize - 1));
      - for ownerKind==='user', the returned burst cap must be at least FISH.minBurstSpeed;
      - FISH.minBurstSpeed must be greater than PREY.maxSpeed + PREY.speedMargin, so even the largest depleted user fish in burst has a speed advantage over the smallest ordinary NPC prey while that prey is fleeing/accelerating;
      - ordinary NPC prey uses PREY.maxSpeed as an active-acceleration ceiling in prey.js#capPreySpeed even when mode==='burst'; if an NPC is already above PREY.maxSpeed from a previous higher target, capPreySpeed preserves the previous actual speed and lets drag brake it;
      - capPreySpeed must not raise fleeing prey to FISH.minBurstSpeed; that floor belongs to hunter/predator burst movement, not prey escape movement.
    spendEnergy runs only for active burst thrust: speedLevel >= 31 and a non-zero acceleration vector in the current tick. speedLevel 0..30 and inertial braking after burst thrust stops preserve size, even while actual velocity is still above the cruise range. In burst, multiply the base size loss by burstEnergyFactorOf(fish.speedLevel): 1 + ENERGY.burstExtraSpendFactor*(speedLevel-31)/68 for levels 31..99. Level 31 remains available at the minimum size and does not reduce size below the owner-specific minimum.
    spendEnergy clamps NPC fish to ENERGY.minSize and user fish to ENERGY.userMinSize.
    ENERGY.userMinSize must be greater than PREY.minSize * PREDATION.eatRatio, with a small margin, so the smallest fully grown ordinary NPC remains edible by a maximally depleted user fish.  # @ds:f51831f5 @ds:6aa7c828 @ds:d4f6a1c2 @ds:9ce87fee
  player_input: |
    Pointer, keyboard, touch, and joystick input affect only the current client's user fish.
    Keyboard input is always active after join and has movement priority over pointer, touch, and joystick steering in every selected mode.
    The active control-mode switch selects only the experimental screen-input override: pointer or touch. The visual joystick is the default screen input whenever the active mode is not pointer or touch.
    createControlModeState(deviceType) initializes activeControlMode to joystick for every device type; later user selection through the existing mode switch can choose pointer or touch as experimental overrides or return to joystick/default.
    Relative speed is represented as speedLevel 0..99. Levels 1..30 are cruise, levels 31..99 are burst.
    Keyboard movement keys select speedLevel 30 when no higher keyboard speed key is held. Keyboard Space and key 1 select speedLevel 31, key 2 selects speedLevel 65, key 3 selects speedLevel 99; when several are held, use the highest selected level.
    Pointer mode mouse hold selects speedLevel 31.
    Touch mode uses a single primary touch around the current user fish screen position. Compute the vector from that screen position to the touch, divide by the invisible touch control radius, clamp to 0..1, and map linearly to speedLevel round(unit*99). This same vector direction is used for steering.
    Joystick mode uses the visible joystick base in the lower-right interface area. Compute the vector from the joystick base center to the pointer/touch and divide by the joystick base radius, clamped to 0..1. Map joystick radial unit to speedLevel with an expanded cruise radius: unit 0..(30/99*1.5) maps to speedLevel 0..30, and the remaining outer unit range maps to speedLevel 31..99. This same vector direction is used for steering.
    The touch control radius is min(112px, 80% of min viewport side / 2) and is centered on the current user fish screen position only in activeControlMode == touch, so its invisible diameter is twice the unchanged 112px visible joystick diameter unless the viewport cap is smaller.
    controls.js#speedLevelToControlMagnitude is the inverse of the joystick radial mapping and is used by availability clamping and ring placement. The cruise/burst visual boundary is level 30 at 1.5*(30/99) of joystick radius.
    No separate vulnerability toggle exists in UI or input state.
    Implement buildInputPayload() in main.js:
      - read keySteer(input.keys) first;
      - if keySteer returns a vector, use it and ignore pointer steering for that frame;
      - otherwise use pointerSteer only when activeControlMode is pointer and pointer.active;
      - otherwise use pointerSteer only when activeControlMode is touch and pointer.active and touchDown is active, using the pointer vector relative to the current user fish;
      - otherwise use joystickSteer;
      - normalize the selected vector before sending;
      - set desiredLevel=speedLevel(input, activeControlMode), then set speedLevel=availableSpeedLevelForSize(currentUserFish.size, desiredLevel).
    controls.js#speedLevel must check keyboard speed keys before mode-specific controls so Space can enable v31 in keyboard, pointer, touch, and joystick modes.
    Implement sendInputIfChanged(now):
      - compute payload = buildInputPayload();
      - compute key = signed-thousand x/y plus speedLevel, using the same quantization as protocol.encodeClientControl;
      - if key differs from lastSentInputKey, call net.input(payload) immediately and update lastSentInputKey/lastInputFlushAt;
      - otherwise call net.idle() only when now-lastInputFlushAt >= 1000ms.
    Implement controls.js key state cleanup:
      - keydown adds normalized movement keys, Space, and keys 1/2/3 to input.keys, and prevents default browser scrolling/action for those controls;
      - keyup removes normalized keys;
      - window blur and document visibilitychange clear input.keys, pointerDown, and touchDown so lost keyup events cannot leave movement or burst stuck;
      - keyboard movement does not change activeControlMode and does not need a pointer lock flag because keySteer is always read before experimental pointer/touch or joystick steering.
    Client input is encoded as cXXYYmods where X/Y are signed thousandths
    of normalized steering and v1..v99 in mods means speedLevel. Absence of v means speedLevel 0. The legacy b modifier is not supported.  # @ds:91e32235 @ds:70871bc5 @ds:c2aeb63a @ds:cf6ad7d6 @ds:5377d065 @ds:671e9773 @ds:e6be3c03
  game_surface_input_ownership: |
    CSS and input event handlers split browser interaction by surface:
      - #game, #hud game buttons, #control-modes, and #joystick-panel use
        user-select:none, -webkit-user-select:none, touch-action:none where
        game gestures are handled, and suppress context menu on the canvas;
      - createInput uses non-passive touch listeners for canvas movement so it
        can preventDefault for game steering gestures;
      - #join and form fields keep normal text input, selection, color picker,
        button activation, and label behavior.
    This keeps browser scroll/zoom/navigation gestures from taking precedence on
    the game surface while preserving ordinary form controls.  # @ds:5d92a6ef
  version_ui: |
    server.js computes appVersion once at launch from current UTC date/time and
    the git commit digest when available. It serves /version.json as
    `{ "version": "YYYYMMDD-HHMM-<digest>" }`; when git digest is unavailable,
    use "nogit" as the digest segment.
    index.html contains a persistent #app-version span in the HUD/service area.
    main.js#showAppVersion fetches /version.json on init and writes the version
    string to #app-version; fetch failure displays the current document load date
    plus "unknown" digest rather than hiding the field.  # @ds:8d13f6a2
  mobile_joystick_layout: |
    style.css owns the on-screen joystick layout.
    Define --joystick-footprint-size as min(340px, 40vmin), where vmin makes the cap follow the smaller viewport side in both portrait and landscape. Keep --joystick-knob-size as the existing responsive knob diameter and derive --joystick-size as calc(var(--joystick-footprint-size) - var(--joystick-knob-size)). Mobile media rules may change only --joystick-knob-size; they must not replace the footprint-derived --joystick-size with a fixed base diameter.
    #joystick-panel is a fixed square whose width and height are exactly --joystick-footprint-size. Anchor it to the lower-right with the existing safe-area-aware right and bottom offsets. It is shown after join whenever activeControlMode is not pointer or touch and hidden while pointer or touch experimental mode is active. Do not stretch the panel toward the left viewport edge.
    #joystick-base is the visible circular joystick control anchored one half knob diameter inward from the panel's lower-right edges. Its width and height are --joystick-size, so the knob remains within the panel when its center reaches the base edge. Rings remain inside the base and the complete visual footprint remains within min(340px, 40% of min(viewport width, viewport height)).
    Joystick speed comes from pointer displacement from the visible joystick base center in the same radial control that owns steering.
    setupJoystickControls stores input.joystick.rawVector as the normalized actual displacement with magnitude 0..1, and stores input.joystick.vector as the same direction clamped to the current available speed radius for internal consistency. controls.js#joystickSteer uses rawVector so steering strength follows the held pointer position; controls.js#speedLevel maps rawVector magnitude to desired speedLevel 0..99 with the expanded cruise radius before buildInputPayload clamps it through availableSpeedLevelForSize. main.js#updateJoystickBurstAvailability computes the current available speedLevel for the user fish and redraws rings for v=30 cruise boundary plus selected burst availability levels. If the current user fish has applied speedLevel 1..99, main.js#updateJoystickCurrentBurstRing shows #joystick-current-burst-ring at speedLevelToControlMagnitude(fish.speedLevel), uses a 2px border, and colors it through main.js#joystickCurrentSpeedColor: levels 1..30 return the blue cruise color, and levels 31..99 return the existing pink burstSpeedColor scale. speedLevel 0 hides that ring.  # @ds:cd1c5776 @ds:0eef2d19 @ds:e41821af
    index.html#game-menu contains #burst-endurance-table with rows for speedLevel v=1..99. main.js#updateBurstEnduranceTable reads BURST_ENDURANCE_SIZE_THRESHOLDS and currentUserFish.size, writes mode, minimum size threshold, current availability, energy factor, expected size loss, and the time window for each speed. updateGameMenu refreshes the table while the menu is open and whenever current fish state changes.  # @ds:cff27cd5
    index.html#game-menu contains #viewport-fish-capacity with option values 10, 20, 30, and max. constants.js exports VIEWPORT_FISH_CAPACITY with options ['10','20','30','max'] and defaultValue '20'. main.js owns viewportFishCapacity as client display state, initializes the select to the default, updates that state from change events through setViewportFishCapacity(value), and passes viewportFishCapacity into render(), viewportToWorld(), and worldToViewport() calls that convert current pointer/touch positions.  # @ds:e001d967
    The visible joystick layout remains independent from the current user fish screen position.  # @ds:b43d2f95 @ds:cd1c5776 @ds:6896cdc6
  responsive_join_and_status_layout: |
    style.css owns the responsive repair. #join must use overflow-y:auto, align-items:center, and viewport-relative block padding so #join-form is vertically centered whenever it fits, and otherwise is never clipped when its content height exceeds a short viewport; at landscape/short-height breakpoints reduce only spacing and typography while retaining every required form control and exact text. The form itself may scroll within the entry layer and must remain keyboard/touch operable.
    #world-info is the bottom status strip. In landscape/short-height layouts, give it an explicit compact height, full-width horizontal grid, opaque/semi-opaque background, and its own top border so its occupied rectangle is visually identifiable and does not become a large left overlay. Keep status values readable and preserve the existing world-info items.
    #joystick-panel must use bottom: calc(var(--bottom-info-bar-height) + safe-area-aware gap) in every responsive layout, so its complete footprint is above the status strip. Do not use a bottom offset that ignores --bottom-info-bar-height.  # @fix:3196de1d
  predation_eligibility: |
    canEat(predator, victim) requires burst, size eligibility, and canBeVictimOf.
    canBeVictimOf rules:
      - user fish with active fryAge is protected and remains alive when another
        fish tries to eat it.
      - NPC and abandoned user fish have no user-tier protection.
      - paid user fish can be eaten only by another paid user fish.
      - free user fish can be eaten by any ordinary eligible predator.
      - user fish with active fryAge can feed on NPC fish and shreds, but
        collectFeedingCandidates excludes user-fish victims for that feeder.
    There is no separate player vulnerability mode.  # @ds:32745a4f @ia:01fe68fa @ds:5377d065
  user_attack_window: |
    isLeaveBlockedByUserAttack returns true when another user fish is in burst,
    moving toward current user fish, and distance / currentBurstSpeed < 2.
    This rule blocks explicit leave only. Socket disconnect still follows
    reconnect grace then NPC conversion.  # @ds:8917ad63
  eating_resolution: |
    resolveWorldEating(world,rng) runs on the server after all fish integration for the tick.
    For each predator/victim pair:
      - skip same object and already removed victims;
      - call isAttackContact(predator,victim) before canEat(predator,victim);
      - canEat requires predator.mode==='burst', isEdibleBySize, canBeVictimOf, and isAttackContact.
    isAttackContact(predator,victim):
      - use canonical circles centered at fish.pos with radii derived from collision_area geometry;
      - require predator.mode==='burst' and speed > 1e-3;
      - compute mouth/head direction from current facing/velocity and reject victims outside the forward mouth cone;
      - compute relativeVelocity = predator.vel - victim.vel and separation = victim.pos - predator.pos in the nearest toroidal image;
      - require dot(relativeVelocity, separation) > 0 so the current motion increases overlap;
      - allow contact only when center distance < predator.radius + victim.radius; forward attack reach remains available for threat, spawn, and steering heuristics, but it must not make fish candidates edible before circle intersection.
    On NPC victim: grow predator, splice victim from world.fish, and adjust outer loop index when needed.
    On user victim: grow predator and respawnUserFishAfterEating(world,victim,rng) in place, preserving id, clientId, temporaryConnectionCode, userName, userColor, and userTier, then start the 3 second player start window.  # @ds:75a5aa4f @ds:39305789 @ds:4c7a2b91 @ds:9d62f0a7 @ds:a3e394a8 @ds:b39c93a5 @ds:b024b514 @ds:98224ab9 @fix:3e7a9c21
  client_prediction_and_render: |
    main.js owns snapshotBuffer and clientBubbles outside state.world.
    main.js also owns debugMode, debugPositionTraces, and latestAbsoluteServerPositions outside state.world.
    createClientNet.onSnapshot pushes structuredClone(world) into snapshotBuffer; it must not copy or reset clientBubbles.
    renderState(now) returns a derived current-position estimate from the newest authoritative snapshot, not an intentionally delayed past snapshot.
    extrapolateWorld(snapshot,elapsedSeconds):
      - copy width/height and all non-position fish fields from the newest snapshot;
      - for each fish, compute visual position as fish.pos + fish.vel * elapsedSeconds;
      - for each shred, compute visual position as shred.pos + shred.vel * elapsedSeconds;
      - do not compute mouth, teeth, fin, swim phase, or burst kick as protocol-controlled snapshot fields;
      - wrap extrapolated positions back into world bounds on both axes;
      - clamp elapsedSeconds to a short maximum so a stalled socket cannot send fish flying indefinitely;
      - never invent fish that are absent from the newest snapshot.
    Client decor:
      - main.js owns a clientFishDecor Map keyed by fish id;
      - after extrapolation and before render, applyClientFishDecor advances swimPhase, burstKick, mouthOpen, mouth hold timers, and local exhale cycles using dt;
      - the input facts for decor are synchronized fish velocity, mode, size, eatenFishCount deltas, and shredEatCueCounter deltas;
      - protocol rows must not encode or decode mouthOpen, teeth state, swimPhase, burstKick, mouth timers, or any other visual-only fish decor field;
      - server authority over movement must not become server authority over mouth, teeth, or fin animation.
      - clientFishDecor stores an exhale state object per fish id with the same shape as fish.js#makeFish.exhale; this state is client-only and removed when the fish id is absent from the newest visible world.
      - updateClientDecorState tracks previous displayed mode separately from burstSwimming and stores the last confident movement direction. When fish.mode transitions cruise<->burst, call emitMotionCueBubbles once to append 1..2 ordinary bubbles to clientBubbles. When the current confident movement direction differs from the previous confident movement direction by more than 100 degrees, call the same cue. Do not emit this cue solely because speedLevel changes inside active burst.
      - updateClientDecorState stores lastEatenFishCount per fish id. When a visible fish's synchronized eatenFishCount increases, call requestExhale on decor.exhale with an eating red-bubble ratio of 0.4; this request is client-only and may queue behind an already active exhale cycle.
      - updateClientDecorState also starts a 0.3s eatingCruiseHold when eatenFishCount increases. During that hold, set the visible fish's mouthOpen to 0 and render it through the cruise visual state locally. Do not write this cruise hold to protocol rows or server fish.mode.
      - updateClientDecorState stores lastShredEatCueCounter per fish id. Initialize this field to 0 when client decor is first created so a fish that first appears with a positive synchronized shredEatCueCounter still plays the cue instead of treating that value as already consumed.
      - When the synchronized shredEatCueCounter increases, start a local 0.3s shredBurstHold and set mouthHold/mouthEatenSize for compatibility with non-SVG rendering. While shredBurstHold is active, applyClientFishDecor sets only the temporary visible fish.mode to 'burst' so the existing SVG shape_burst mouth opens for cruise-state shred feeding. Do not write this hold to protocol rows or server fish.mode.
      - applyClientFishDecor attaches decor.exhale to the temporary visible fish, calls runExhaleCycle(fish, clientBubbles, rng, dt), then copies fish.visualScale from the exhale cycle back into rendered fish state. The cycle may push bubbles into clientBubbles and displace existing client bubbles, but must not write to world.bubbles or protocol fields.
    frame(now):
      - compute dt from previous animation frame and clamp with LOOP.maxDt;
      - const visibleState = renderState(now);
      - call applyClientFishDecor(visibleState.world, clientBubbles, dt, clientRng) before render and before client bubble emission;
      - call updateSizeDeltaLabels(visibleState.world, dt) after decor and before render so labels use the same visible current-user size as the frame;
      - call advanceClientBubbles(clientBubbles, clientBubbleEmitters, visibleState.world, dt, clientRng);
      - call recordDebugPositionTraces(now, visibleState.world) only when debugMode is true;
      - call render(ctx, { ...visibleState, clientBubbles, sizeDeltaLabels, debug: { enabled: debugMode, positionTraces: debugPositionTraces } });
      - call sendInputIfChanged(now) independently from render interpolation.
    updateSizeDeltaLabels(visibleWorld, dt):
      - main.js owns `sizeDeltaLabelState = { fishId, lastSize, remainder, labels }` outside state.world;
      - find the current user fish by visibleWorld fish id;
      - when no current user fish exists or the id changes, reset fishId, lastSize, remainder, and labels without emitting a catch-up label;
      - while the current user fish is in the start window and its size is at or
        below PLAYER.startSize, update lastSize to the visible fish size, clear
        remainder, keep existing labels aging, and do not emit positive start
        growth labels;
      - when the current user fish is still in the start window but has grown
        above PLAYER.startSize through feeding, compute the label delta from
        max(previous lastSize, PLAYER.startSize) so the automatic nominal growth
        portion remains hidden and only the excess feeding growth can emit;
      - compute sizeDelta = fish.size - lastSize, add it to remainder, then update lastSize to fish.size;
      - while Math.abs(remainder) >= 0.1, emit one label step with value = sign(remainder) * 0.1 and subtract that step from remainder;
      - if a single frame contains multiple steps in the same direction, coalesce them into one label whose value is the total emitted amount rounded to one decimal;
      - labels store `{ fishId, value, age, life, yOffset }`, where value > 0 renders green with a leading plus and value < 0 renders red;
      - each frame increases age, removes labels with age >= life, and computes yOffset from age/life so the label rises slightly while fading;
      - labels are client-render-only and must not be written to protocol rows, world.fish, fish.size, or server state.
    render(ctx,state) projects sizeDeltaLabels through the same toroidal render world as fish: each label attaches to the projected current-user fish position and draws above it with alpha from remaining lifetime.  # @ds:c2d7f4a1
    advanceClientBubbles(clientBubbles, clientBubbleEmitters, world, dt, rng):
      - remove emitter entries whose fish ID is absent from world.fish;
      - for each fish in world.fish, read or create emitter state `{ bubbleTimer: 0, bubbleBurstRemaining: 0 }` from clientBubbleEmitters by fish.id;
      - call emitBubble with a temporary fish object that combines current visual fish geometry with the local emitter fields;
      - after emitBubble, write the updated bubbleTimer and bubbleBurstRemaining back to the emitter entry;
      - push non-null emitted bubbles into clientBubbles; emitted bubble objects must carry `{ pos, radius: 0, targetRadius, vel, life, age: 0, alpha: 0, phase, color? }`, where `targetRadius` is the normal visible radius computed from fish size and `color` is omitted for ordinary white bubbles or set to `red` for eating-exhale red bubbles;
      - call advanceBubbles(clientBubbles, world, dt);
      - do not store these bubbles in world.bubbles.
    advanceBubbles owns bubble motion and birth/fade animation: increment `age`, decrement `life`, move by velocity, compute `birth = clamp(age / BUBBLE.birthDuration, 0..1)`, compute `fade = clamp(life / BUBBLE.life, 0..1)`, set `radius = targetRadius * easeOut(birth)` and `alpha = min(birth, fade)`. Bounds removal must use the larger of current radius and targetRadius so a just-born zero-radius bubble is not removed incorrectly.
    render(ctx,state) reads bubbles from state.clientBubbles first, then state.world.bubbles only for legacy single-process mode. render.js#drawBubble uses the ordinary white/blue style when bubble.color is absent and a red fill/stroke style when bubble.color is `red`.
    Camera viewport follows current client user fish via worldToViewport(world, followed, canvas, options).
    Rendering projects game-world units to canvas pixels. render.js#viewportScaleForFishCapacity(world, canvas, value) computes nominalStartDiameter = FISH.baseRadius * sqrt(PLAYER.startSize) * 2, numericScale = min(canvas.width, canvas.height) / (Number(value) * nominalStartDiameter) for 10/20/30, and maxScale = max(canvas.width / world.width, canvas.height / world.height). This maxScale uses the cover scale: at least one complete world axis fits the corresponding screen axis, while the other axis may extend beyond the viewport. The function then returns max(numericScale, maxScale). For value max it returns maxScale. worldToViewport uses that scale and keeps the followed fish centered. The scale is display-only and must not write to world, fish, protocol rows, or server state.  # @ds:e559831a @ds:7b9a7984 @ds:e001d967 @ds:d6cebf86 @ia:3c4d5e6f @ia:5a6b7c8d
  toroidal_viewport_projection: |
    render.js owns viewport projection only; it must not mutate state.world, fish.pos, protocol rows, or snapshotBuffer.
    worldToViewport(world, followed, canvas, options) keeps the followed fish's canonical position as the viewport focus.
    Before drawing fish, bubbles, labels, hit-test overlays, and debug relative/absolute traces, render.js builds a derived render world:
      - choose anchor = followed.pos when a followed user fish exists, otherwise world center;
      - for every drawable point p, compute projected p' independently per axis with nearestToroidalCoordinate(pAxis, anchorAxis, worldAxisSize);
      - nearestToroidalCoordinate(value, anchor, size):
          candidates = [value - size, value, value + size]
          return the candidate with the smallest absolute distance to anchor
      - for fish, copy the fish object shallowly and replace only pos with the projected pos;
      - for bubbles and debug traces, copy the item shallowly and replace only pos with the projected pos;
      - keep velocity, facing, size, owner, user identity, and decor fields unchanged.
    render(ctx,state) draws the projected copies, not canonical state.world.fish positions.
    drawDebugWorldRepeatBounds draws at least the canonical rectangle and the neighboring repeated rectangles around the anchor so the dashed boundary remains meaningful when the viewport is centered near an edge.
    viewportToWorld(point, world, followed, canvas, options) returns the inverse projected coordinate in continuous viewport space using the same viewportFishCapacity option as rendering; callers that need canonical simulation coordinates must wrap the result back into [0,width) x [0,height).
    main.js#handleInspectClick must hit-test against the same projected fish copies used by render, then report serializeFish for the original canonical fish object.
    main.js#buildInputPayload may use the continuous pointer coordinate relative to the followed fish for steering, but must not write that coordinate into world state.
    Edge examples:
      - width=100, anchor x=90, fish x=10 => projected fish x=110.
      - width=100, anchor x=2, fish x=22 => projected fish x=22.
      - width=100, anchor x=2, fish x=90 => projected fish x=-10.
    This fixes visual continuity only; canonical wrapPosition remains the simulation authority.  # @ds:7b9a7984 @ds:c83f4c1e @ia:dd909d1a
  debug_visualization: |
    main.js owns a client-only debugMode boolean and a debugPositionTraces array.
    main.js owns lastDebugTraceAt and samples trace points no more often than DEBUG.traceSampleMs, so long sessions cannot append one trace per animation frame per fish.
    #debug-mode-toggle is a game-menu control; toggleDebugMode() flips debugMode from this control or debug key, must not send any socket message, and must not alter state.world.
    protocol.js#applyWorldSync already identifies absolute sync messages; extend its diagnostics so each absolute parsed fish row exposes `{ id, pos }` using the server absolute position before client extrapolation.
    main.js stores those absolute server positions in latestAbsoluteServerPositions during onSnapshot/onDiagnostics handling.
    recordDebugPositionTraces(now, visibleWorld):
      - return immediately when now-lastDebugTraceAt < DEBUG.traceSampleMs; otherwise set lastDebugTraceAt=now;
      - for each fish in visibleWorld.fish, append `{ kind:'relative', fishId: fish.id, pos: { ...fish.pos }, createdAt: now, fadeStartAt: now + 3000 }`;
      - for each latestAbsoluteServerPositions entry, append `{ kind:'absolute', fishId, pos, createdAt: now, fadeStartAt: now + 3000 }`;
      - prune traces after fade completes; alpha remains 1 until fadeStartAt, then decreases smoothly to 0 over DEBUG.traceFadeMs.
    render.js#render passes the active viewport transform to debug drawing after bubbles/fish so overlays are visible.
    drawDebugWorldRepeatBounds(ctx, world) draws a rectangular stroke from (0,0) to (world.width,world.height).
    drawDebugFishCollisionRadius(ctx, renderWorld.fish) runs while the viewport transform is active, after fish are drawn and before position traces; it iterates every displayed fish in the projected render world and draws a translucent circular halo centered on fish.pos with radius fish.radius. Use the unscaled collision/contact radius, not fish.radius * visualScale, because predation contact uses fish.radius. The overlay is read-only and must not mutate fish, world, protocol, or server state.
    drawDebugPositionTraces(ctx, traces, now) draws relative traces as yellow dots and absolute traces as green dots using each trace alpha.
    Debug does not draw a map. The map is drawn by world_map_ui only when worldMapVisible is true.
    These overlays are render-only diagnostics and must not mutate world, fish, protocol rows, or server state.  # @ds:59c1185f @ds:7435b6ce @ds:727e9afe
  compact_protocol: |
    Protocol payloads are ASCII strings over WebSocket with first-character dispatch.
    Implement client message codecs:
      - encodeClientJoin({userColor,userName,userTier}) => n:${hexNoHash}:${base64urlName}:${u|p}
      - encodeClientReconnect(token) => r:${token}
      - encodeClientPing(n) => p:${n}
      - encodeClientControl({accel,speedLevel}) => c${signedThousandX}${signedThousandY}${speedLevel>0 ? `v${speedLevel}` : ''}
      - parseClientMessage mirrors these shapes and clamps invalid control digits to 0.
    Implement server message codecs:
      - encodeIdentity(id,token) => i:${id}:${token}
      - encodeEvent(type,data) => e:${type}:${data}
      encodeObjectRemoval(kind,id) returns x:${kind==='shred' ? 's' : ''}${id}.
      encodeWorldCycle(world, previousState, cycle) returns { absoluteText, relativeText, cells, state }.
    encodeWorldCycle algorithm:
      - use SYNC.cellSize=100 and assign every fish/shred to floor(pos.x/100),floor(pos.y/100) by its center;
      - maintain server birthCycle maps by transport identifier; a row is new while cycle-birthCycle < 10;
      - generate an absolute row and relative row for every object exactly once; a new object's relative-set row is its full absolute row prefixed with n;
      - absolute row positions are localX=pos.x-cellX*100/localY=pos.y-cellY*100; ordinary relative positions are deltas from the immediately preceding server cycle;
      - group both row sets in the same deterministic cell order, join each into one shared string, and store per non-empty cell {key,cellX,cellY,absoluteStart,absoluteEnd,relativeStart,relativeEnd}; ranges exclude message headers and delimit complete joined rows;
      - return next snapshot maps for the next cycle baseline; do not emit deletion rows.
    server.js#queueWorldFragments:
      - sort non-empty cells by shortest toroidal squared distance from cell center to the client's current fish, forcing its containing cell first;
      - build `a:N:X:Y|ROWS` from absolute ranges for the first four cells, and `|N:X:Y|ROWS` from relative ranges for the rest;
      - when N%20===0, use absolute ranges and a-prefix for every cell;
      - replace any unsent per-socket queue when a newer cycle is prepared; send one queued fragment per setImmediate turn while checking the queue generation so an old callback cannot continue an replaced queue;
      - empty cells have no ranges and never enter a queue.
    Fish row shape:
      ID:TYPE EATEN_OPT:SIZE_ABS:COLOR1_OPT:COLOR2_OPT:NAME_OPT POS_X_OPT:POS_Y_OPT MOVING_ANG:MOVING_SPEED STATE_MODS
    Full shred row shape:
      sID SIZE:GEOM_AREA:INITIAL_GEOM_AREA:COLOR_HEX:LAYERS_HEX:SEED:DECAY_AGE POS_X:POS_Y MOVING_ANG:MOVING_SPEED
    Dynamic shred row shape:
      dID POS_X:POS_Y MOVING_ANG:MOVING_SPEED DECAY_AGE:LAYERS_HEX_OR_EQUALS
    encodeFishRow includes shredEatCueCounter as a numeric state mod `sN` only
    when the counter is greater than zero, and parseFishRow preserves the previous
    value when the mod is absent. The value is domain-visible event state for
    local mouth cue detection, not mouth animation state.
    encodeFishRow also includes user start-window age as `gN` and user active
    lifetime as `lN`, where N is seconds in tenths. parseFishRow exposes them as
    fish.fryAge and fish.playerActiveAge seconds so start growth suppression and
    the lifetime bar are bound to synchronized server state and PLAYER.maxLifetimeSeconds.
    encodeFishRow encodes burst fish state as `bN` where N is clamped to 1..99.
    parseFishRow decodes `vN` into fish.speedLevel=N and derives mode from that value; rows with no v mod decode as fish.mode='cruise' and speedLevel=0.
    applyWorldFragment(world,message,transportState,receivedAt):
      - parse absolute/header N/cellX/cellY; ignore N lower than transportState.currentCycle;
      - on first fragment of a greater N, evaluate the completed previous cycle: objects whose last received cycle equals N-2 start temporary fade-out only now; store receivedAt as the new cycle clock;
      - parse an optional leading n before each existing object identifier; n makes that row full/absolute even under a relative fragment;
      - reconstruct absolute positions from cell origin; apply an ordinary relative row only when object.lastSyncCycle===N-1; otherwise ignore the row and leave the object hidden until a full row;
      - full rows create unknown objects and set fade-in 0->1 for 0.2s; full rows for fading/hidden objects reverse from their current alpha to 1 over 0.2s; all accepted rows set lastSyncCycle=N;
      - never remove an object because a cell or row is absent; preserve fish/shred arrays across fragments.
    applyObjectRemoval(world,message,transportState,receivedAt):
      - resolve fish numeric identifiers and shred s-prefixed identifiers;
      - tombstone the transport identifier with its current cycle so queued rows from that cycle cannot revive it; a full absolute row from a later cycle creates the deliberately reused ID as a new object;
      - freeze the object at its current extrapolated display position, zero velocity, and start ease-out opacity from current alpha to zero over 0.1s; remove it from local cache after completion.
    client-net.js logs absolute-position drift diagnostics after absolute syncs:
      - select the current user fish plus the first two NPC fish from the diagnostic rows;
      - use the elapsed time since the previous sync and the previous client velocity to predict the client-side current position at receive time;
      - print a compact console table with id, role, previous client position, predicted client position, absolute server position, elapsed ms, error dx/dy, and error distance;
      - skip rows with no previous client position.
    server.js#tick compares transport identifiers before and after the authoritative step and immediately broadcasts x:${TRANSPORT_ID} for every removed fish or shred. `broadcastWorldSync` calls encodeWorldCycle exactly once per sync interval, stores its shared strings/ranges and state, then only slices ranges into per-client ordered queues. State mods include a, bN, f, sN, gN, and
    lN. Names use base64url; colors use hex without #; type is u/p/n. State mods
    are domain/network facts only. Do not add protocol fields or mods for visual-
    only mouth, teeth, fin, swim phase, burst kick, or mouth hold state. main.js computes each object's sync opacity and cycle-clock extrapolation per frame; render.js applies syncOpacity around the complete fish or shred draw.  # @ds:839f8cd0 @ds:5a4d3d6d @ds:671e9773 @ds:4fad33f8 @ds:682570c7 @ds:c39827ed @ds:e047bbdf @ds:6c8c56e7 @ds:ea18a088 @ds:f51a5030 @ds:a16328a6 @ds:2afd71a0 @ds:9f50b1be @ds:0aaccaf8 @ds:28d9098a @ds:8c663384
  input_latency: |
    Do not throttle changed input in client-net.js.
    client-net exposes:
      - input(payload): sends encodeClientControl(payload) immediately when joined;
      - idle(): sends encodeClientPing(++pingCounter) when joined.
    client-net must not run a separate ping setInterval while main.js owns the idle cadence.
    main.js owns throttling:
      - changed key/control state sends input() on the same animation frame;
      - unchanged state sends idle() at 1000ms cadence.
    Reset lastSentInputKey after identity i:${ID}:${token}.  # @ds:10baf178 @ds:22fd3ab4 @ds:671e9773
  fish_body_color_visual: |
    render.js#drawFish resolves the base body fill before drawing any user fish decoration.
    For ownerKind='user':
      - body silhouette fill must use fish.userColor directly for the whole fish body base;
      - shadows, belly, gill lines, fins, highlights, and decorative fragments must be drawn as transparent black/white overlays on top of the base fill, using rgba/globalAlpha or compositing that lets userColor remain visible;
      - do not use fixed replacement colors such as hard-coded cyan shadow/light fills for user-fish body regions;
      - mouth cavity, teeth, eyes, and text label may keep semantic non-body colors because they are not body-color decoration.
    For ordinary NPC fish, keep yellow-toned HSL palette.
    For abandoned former user fish, draw a top-to-bottom former-user-color to
    NPC-yellow gradient only for body_cruise/body_burst base shapes. Non-body
    SVG elements that use currentColor resolve to ordinary NPC yellow, and
    authored shade/highlight/decorative layers remain layered over the body base
    without becoming part of the former-user gradient.  # @ia:32288dfb @ds:f883f90c @ds:bfd5a97a @ds:c3708d14
  fish_svg_geometry_visual: |
    render.js owns loading/parsing the published web-canvas/assets/fish2.svg runtime
    copy of the authored ds/assets/fish2.svg geometry into reusable draw paths keyed
    by semantic SVG ids. The parsed or embedded fallback data must use the exact
    source SVG viewBox, path/circle coordinates, proportions,
    element-relative positions, semantic ids, fill styles, fill opacity, stroke
    styles, linearGradient definitions, gradient stops, stop opacity, and
    currentColor usage. Canvas drawing resolves currentColor from the current fish
    color at render time; other SVG paint semantics are preserved from the asset.
    Canvas drawing may apply visibility, scale, facing, and animation transforms,
    but must not redraw the fish silhouette or replace authored gradients and fills
    with hand-authored substitute paint.
    loadFishGeometry parses SVG elements once into reusable render commands and
    gradient definitions. drawFish must not create Blob, ObjectURL, Image, DOMParser,
    XMLSerializer, or generated SVG text while rendering a frame; it draws the
    already parsed paths/circles synchronously with Canvas 2D. Missing geometry may
    skip only the fish body for that frame, but a cache miss must never make an
    otherwise parsed fish disappear.
    Keep collision_area, shape_cruise, shape_burst, and fin_* ids addressable in code.
    The renderer anchors the fish at collision_area center, scales fish.size from
    collision_area diameter, and keeps predation/debug collision radius tied to
    that canonical circle rather than to decorative fins or mouth reach.
    drawFish chooses shape_cruise when fish.mode is cruise and shape_burst when
    fish.mode is burst. fin_* elements receive the current swim phase transform
    from updateSwimMotion and remain attached to the same fish transform.  # @ds:df06827a @ds:b024b514 @ds:1e323735 @ds:bd354b7a @ia:2f6e7a91
  fish_mouth_visual: |
    render.js#drawFish uses the parsed SVG visual geometry for the mouth and teeth.
    Do not draw an additional canvas mouth overlay on top of the authored SVG shape.
    The visible mouth state comes from the local rendered fish mode: burst uses the
    authored burst shape with its attack mouth/teeth, and cruise uses the authored
    cruise shape with the mouth closed.  # @ds:975ca168 @ia:9c0d1e2f
  fish_facing_and_burst_mouth_state: |
    fish.js#updateFacing derives visual facing from fish.vel.x with FISH.facingThreshold hysteresis; do not add a server protocol field for facing direction.
    protocol.js may preserve previous client facing while decoding rows, but the client fish update/render path must be able to derive facing from movement.
    In multiplayer rendering, main.js#updateClientDecorState computes chaseOpen on the client when fish.mode==='burst' and synchronized speed is above FISH.facingThreshold.
    Do not encode mouthOpen over the protocol; derive the toothed chase mouth locally from synchronized mode and speed.
    Do not open toothed chase mouth for ordinary direction changes, cruise movement, or inertial movement.
    Eating closes the mouth by holding a local client-only cruise visual state for 0.3 seconds after eatenFishCount increases; this visual hold must not mutate server fish.mode or protocol rows.  # @ds:8d0ca6a8 @ds:975ca168 @ia:0bdc556b
  serialization: |
    serializeFish returns structured text.
    Always include type, size, age, eatenFishCount.
    For user fish also include userName, userColor, userTier.  # @do:a7a50f7b
  inspect_click: |
    Convert canvas click to world coordinates using the current viewport transform.
    Find any fish under the click and log serializeFish(fish).  # @ds:2e1570ed

new_or_changed_constants:
  SERVER.tickRate: 30                 # @ds:e4d375ed
  SYNC.snapshotHz: 10                 # @ds:e559831a @ds:682570c7
  SYNC.maxExtrapolationMs: 180        # @ds:e559831a @ds:7b9a7984
  RECONNECT.graceSeconds: 3           # @ds:93a64773
  LEAVE.attackWindowSeconds: 2        # @ds:8917ad63
  REGIME.burstSpeedFactor: 1          # @ds:8869f043
  REGIME.speedLevels: 99              # @ds:8869f043 @ds:07320d39
  REGIME.cruiseMaxSpeedLevel: 30      # @ds:8869f043
  REGIME.burstStartSpeedLevel: 31     # @ds:8869f043
  REGIME.enduranceReserveSeconds: 5   # @ds:07320d39
  REGIME.npcMaxBurstLevel: 70         # @ds:703efd43
  REGIME.burstSpeedExtraFactor: 0.2   # @ds:8869f043
  FISH.baseNoDragSpeed: 650           # @ds:8869f043
  FISH.waterDragByLinearSize: 0.32    # @ds:8869f043
  FISH.minLinearSpeedSize: 0.6        # @ds:8869f043
  ENERGY.burstExtraSpendFactor: 20    # @ds:f51831f5
  WORLD.initialViewportScale: 1.5     # @ds:19c14fea
  VIEWPORT_FISH_CAPACITY.options: [10,20,30,max] # @ds:e001d967
  VIEWPORT_FISH_CAPACITY.defaultValue: "20"       # @ds:e001d967
  WORLD.resizeHysteresisUsers: 1      # @ds:19c14fea
  WORLD.npcDensity: "tunable per area" # @ds:53db39eb
  FRY.startSize: "below nominal spawn size" # @ds:e6ecfbdd
  FRY.growthSeconds: 10               # @ds:e6ecfbdd
  NPC.courageBase: 50                  # @ds:e29aeb93
  NPC.courageJitter: 10                # @ds:e29aeb93
  NPC.courageRandomEvery: 10           # @ds:e29aeb93
  NPC.threatSenseRadius: "maximum distance for potential-predator danger scoring" # @ds:92d5b0c1 @ia:8a4b2f19
  NPC.dangerDirectionSamples: "number of full-circle flee candidate directions" # @ds:4f58a1cd @ia:8a4b2f19
  NPC.huntDangerCorrectionDeg: 20       # @ds:7cb92a44 @ia:8a4b2f19
  NPC.dangerProjectionDistancePx: "forward path length used for danger scoring" # @ds:92d5b0c1 @ia:8a4b2f19
  NPC.dangerRadiusWeight: "weight for threat/self radius in danger scoring" # @ds:92d5b0c1 @ia:8a4b2f19
  NPC.dangerContactWeight: "weight for projected contact-zone proximity" # @ds:92d5b0c1 @ia:8a4b2f19
  NPC.dangerAttackReachWeight: "weight for projected attack-zone proximity" # @ds:92d5b0c1 @ia:8a4b2f19
  NPC.decisionIntervalSeconds: "minimum interval before resampling a new desired direction" # @ds:c6d7e8f9 @ia:8a4b2f19
  NPC.maxTurnRateDegPerSecond: "maximum smoothed desired-direction turn rate" # @ds:c6d7e8f9 @ia:8a4b2f19
  NPC.accelResponsePerSecond: "acceleration smoothing response rate" # @ds:c6d7e8f9 @ia:8a4b2f19
  NPC.maxLifetimeSeconds: 300          # @ds:a6c9e8b4
  SHRED.areaRatio: 0.5                 # @ds:e13d7a52
