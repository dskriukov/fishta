# web-canvas.dsr — Implementation Contract (dsr/imp)
# Generated from: sense/*.dsc + sense/*.air
# Target: local server-authoritative multiplayer Canvas game. This is NOT code.

stack:
  language: javascript (ES modules)
  client_runtime: browser
  server_runtime: Node.js local server
  server_transport: WebSocket
  rendering: Canvas 2D
  client_entry: web-canvas/index.html
  server_entry: web-canvas/server.js

references:
  use:
    - dsr/use/ecs-loop.dsr
  domain:
    - sense/main.dsc
    - sense/world/world.dsc
    - sense/fish/fish.dsc
    - sense/prey/prey.dsc
    - sense/predation/predation.dsc
    - sense/player/player.dsc
    - sense/shred/shred.dsc
    - sense/controls/controls.dsc
    - sense/multiplayer/multiplayer.dsc
    - sense/multiplayer/ws-protocol.dsc
  air:
    - sense/main.air
    - sense/world/world.air
    - sense/fish/fish.air
    - sense/prey/prey.air
    - sense/predation/predation.air
    - sense/controls/controls.air
    - sense/multiplayer/multiplayer.air
    - sense/multiplayer/ws-protocol.air

dsr_generation_rules:
  - "This DSR is an implementation contract: write module/function/state/protocol instructions, not product-level requirement paraphrases."
  - "Every implementation_instructions block must say what code owns state, what function mutates it, what message or data shape is used, and what edge case is handled."
  - "Verification text is only a check aid; IMP must implement from contract_map, data_model, implementation_instructions, and protocol algorithms."

file_plan:
  web-canvas/package.json:          "local server scripts and WebSocket dependency"
  web-canvas/server.js:             "static file server, WebSocket endpoint, authoritative world loop"
  web-canvas/index.html:            "join form, HUD, canvas, module bootstrap"
  web-canvas/style.css:             "fullscreen canvas, compact join/HUD controls"
  web-canvas/src/client-net.js:     "WebSocket client, reconnect code, server snapshots/events"
  web-canvas/src/protocol.js:       "compact socket protocol encoding/decoding and world sync row codec"
  web-canvas/src/constants.js:      "world, fish, regime, density, sync, visual tunables"
  web-canvas/src/vec.js:            "vec2 helpers"
  web-canvas/src/world.js:          "wrap bounds, drag, resize, density field, bubbles"
  web-canvas/src/fish.js:           "fish data, identity fields, swim/grow/facing/decor/serialize"
  web-canvas/src/player.js:         "player fry-stage, active lifetime, old-age respawn"
  web-canvas/src/shred.js:          "server-owned shred spawn, drift, contact, layer nutrition, row helpers"
  web-canvas/src/prey.js:           "NPC wander/flee/density spawn/fry growth"
  web-canvas/src/predation.js:      "eligibility, attack window, overlaps/canEat/resolveEating"
  web-canvas/src/controls.js:       "join form, mode selection, pointer/keys/touch/joystick/hunt/leave input"
  web-canvas/src/hunt.js:           "NPC/user-fish pursuit steering"
  web-canvas/src/step.js:           "authoritative pure-ish server step plus client prediction helper"
  web-canvas/src/render.js:         "viewport-follow render over latest client world view"
  web-canvas/src/main.js:           "client init, join flow, render loop, input send"
  web-canvas/assets/back.png:       "published runtime copy of ds/assets/back.png"
  web-canvas/assets/start.png:      "published runtime copy of ds/assets/start.png"
  web-canvas/assets/join-corner-decoration.svg: "entry-card decorative SVG asset"

