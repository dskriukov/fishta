  SHRED.maxDiameterRatio: "maximum shred visual diameter as a fraction of nominal start-fish diameter" # @ds:7c2f91ad
  SHRED.fragmentation: "controls average sampled shred diameter" # @ds:7c2f91ad @ds:5a9c0e77
  SHRED.sizeJitter: "randomized individual shred size variation" # @ds:7c2f91ad @ds:5a9c0e77
  SHRED.eatSizeRatio: "fish.size threshold relative to shred.size" # @ds:c14f7a08
  SHRED.minFeedingSpeed: "minimum actual speed for eating a shred" # @ds:c14f7a08
  SHRED.mouthCueSeconds: 0.3          # @ds:a2d5936f
  SHRED.initialSpeedMin/Max: "small random launch speed" # @ds:918d4b63
  SHRED.dragMin/Max: "soft water damping range that preserves visible drift" # @ds:8b62d9ce
  SHRED.restSpeed: "speed below which shred stops" # @ds:8b62d9ce
  SHRED.wakeRadiusRatio: "fish wake influence radius multiplier" # @ds:8b62d9ce @ds:ed2b4f19
  SHRED.wakeStrength: "dt-scaled fish wake velocity coupling" # @ds:8b62d9ce @ds:ed2b4f19
  SHRED.wakeMinFishSpeed: "minimum fish speed that can pull shreds" # @ds:8b62d9ce @ds:ed2b4f19
  SHRED.flowWakeRadiusRatio: "flow-field wake radius multiplier" # @fix:6a7b8c9d
  SHRED.flowRearStrength/flowFrontStrength: "rear and front directional wake coupling" # @fix:6a7b8c9d
  SHRED.flowRearInwardStrength: "rear wake side-to-axis entrainment coupling" # @fix:6a7b8c9d
  SHRED.flowAccelerationLeadSeconds: "acceleration contribution horizon for active wake" # @fix:6a7b8c9d
  SHRED.mouthPositionRadiusRatio/mouthSuctionRadiusRatio: "mouth flow position and influence radius" # @fix:6a7b8c9d
  SHRED.mouthSuctionStrength: "open-mouth suction field strength" # @fix:6a7b8c9d
